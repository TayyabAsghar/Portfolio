---
import { about, clients } from "../../data";
import { latestPortfolio } from "../../utils/portfolio";
import {
  ListProjects,
  StyledHeading,
  Main as MainLayout,
} from "../../components";

let globalOffset = 0;
const description =
  "Explore selected portfolio work by Tayyab Asghar across AI products, SaaS platforms, low-code tools, contract automation, retail experiences, and developer-focused applications.";
---

<MainLayout description={description} title={`Work History | ${about.name}`}>
  <section class="relative z-20 max-w-5xl mx-auto my-12 px-7 lg:px-0">
    <StyledHeading
      heading={{ part1: "Work", part2: "History." }}
      description="I am passionate about transforming new ideas into reality through innovative projects. Explore this portfolio to see my latest works, showcasing both creativity and technical expertise."
    />

    {
      clients?.map(({ name, logo, link }) => {
        const companyProjects = latestPortfolio.filter(
          (p) => p.data.company === name,
        );

        const offset = globalOffset;
        globalOffset += companyProjects.length;

        return (
          <ListProjects
            link={link}
            company={name}
            offset={offset}
            brandLogo={logo}
          />
        );
      })
    }
  </section>
</MainLayout>
