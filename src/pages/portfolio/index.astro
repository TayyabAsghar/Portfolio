---
import companies from "../../data/clients.json";
import Layout from "../../components/layout/main.astro";
import PageHeading from "../../components/ui/page-heading.astro";
import ListProjects from "../../components/projects/list-projects.astro";
---

<Layout title="Portfolio | Tayyab Asghar">
  <section class="relative z-20 max-w-5xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title="Portfolio"
      description="I am passionate about transforming new ideas into reality through innovative projects. Explore this portfolio to see my latest works, showcasing both my creativity and technical expertise."
    />

    {
      companies?.map(({ name, logo, link }) => (
        <ListProjects link={link} company={name} brandLogo={logo} />
      ))
    }
  </section>
</Layout>
