---
import { Icon } from "astro-icon/components";
import education from "../../data/education.json";
import experiences from "../../data/experiences.json";
import certificates from "../../data/certificates.json";
import Layout from "../../components/layout/main.astro";
import beyondScreen from "../../data/beyond-screen.json";
import VideoPlayer from "../../components/ui/video-player.astro";
import StyledHeading from "../../components/ui/styled-heading.astro";
import LetsConnect from "../../components/sections/lets-connect.astro";
import OdysseyShip from "../../components/backgrounds/odyssey-ship.astro";
import AboutEducation from "../../components/sections/about-education.astro";
import AboutExperience from "../../components/sections/about-experience.astro";
import AboutCertificate from "../../components/sections/about-certificate.astro";
---

<Layout title="About Me | Tayyab Asghar">
  <section class="relative z-20 max-w-5xl mx-auto my-12 px-7 lg:px-0">
    <StyledHeading heading={{ part1: "About", part2: "Me" }} />

    <div
      class="relative w-full overflow-hidden rounded-xl aspect-video opacity-0 reveal-up"
    >
      <VideoPlayer
        overlay
        volume={0.1}
        id="about-video"
        title="About Me"
        image="/assets/images/about.avif"
        sound="/assets/sounds/about/rain.wav"
        video="/assets/videos/about/house-rainy-day.webm"
      />
    </div>

    <div class="opacity-0 reveal-up delay-200"></div>

    <div class="mt-14">
      <div class="mx-auto max-w-2xl text-center opacity-0 reveal-up">
        <h2
          class="mt-3 text-2xl font-bold text-neutral-900 dark:text-neutral-200 sm:text-3xl"
        >
          Professional Odyssey
        </h2>

        <p
          class="mt-3 text-sm leading-7 text-neutral-600 dark:text-neutral-400 sm:text-base lg:text-lg"
        >
          Tracing the path through product engineering, performance work, and
          full stack execution.
        </p>
      </div>

      <div class="relative mt-12 space-y-0" id="odyssey-timeline">
        <OdysseyShip />

        {
          experiences.map((experience, index) => (
            <AboutExperience
              role={experience.role}
              logo={experience.logo}
              dates={experience.dates}
              company={experience.company}
              website={experience.website}
              detailsPage={experience.detailsPage}
              description={experience.description}
              align={index % 2 === 0 ? "left" : "right"}
            />
          ))
        }
      </div>
    </div>

    <div class="flex flex-col gap-3 opacity-0 reveal-up">
      <h2
        class="mt-3 text-2xl font-bold text-neutral-900 dark:text-neutral-100 sm:text-3xl"
      >
        Education
      </h2>
      <p
        class="text-xs font-semibold uppercase tracking-[0.28em] text-neutral-500 dark:text-neutral-400"
      >
        Piece of paper
      </p>
    </div>

    <div class="px-5 pt-10">
      {
        education.map((edu, index) => (
          <div
            class={`pb-10 border-l border-gray-200 dark:border-neutral-700 opacity-0 reveal-up delay-[${index * 150}ms`}
          >
            <AboutEducation
              logo={edu.logo}
              dates={edu.dates}
              degree={edu.degree}
              website={edu.website}
              location={edu.location}
              institute={edu.institute}
              coursework={edu.coursework}
            />
          </div>
        ))
      }
    </div>

    <section class="mt-16" id="certificates-section">
      <div class="mb-8 flex items-center justify-between opacity-0 reveal-up">
        <div class="flex flex-col gap-3">
          <h2
            class="mt-3 text-2xl font-bold text-neutral-900 dark:text-neutral-100 sm:text-3xl"
          >
            Verified Expertise
          </h2>
          <p
            class="text-xs font-semibold uppercase tracking-[0.28em] text-neutral-500 dark:text-neutral-400"
          >
            Credentials
          </p>
        </div>

        <button
          id="certificate-view"
          type="button"
          class="flex items-center gap-2 px-4 py-2 text-sm font-medium transition-all duration-300 border rounded-full hover:scale-105 bg-neutral-900 text-neutral-100 dark:bg-neutral-100 dark:text-neutral-900 border-transparent hover:border-neutral-600 dark:hover:border-neutral-300"
        >
          <span id="cert-view-text">View all</span>
          <span class="relative w-4 h-4">
            <Icon
              name="eye"
              class="absolute inset-0 w-4 h-4 transition-transform duration-300 icon-eye"
            />

            <Icon
              name="eye-off"
              class="absolute inset-0 w-4 h-4 transition-transform duration-300 icon-eye-off hidden"
            />
          </span>
        </button>
      </div>

      <div
        class="certificate-marquee overflow-hidden opacity-0 reveal-up delay-200"
      >
        <div
          id="cert-track-marquee"
          class="certificate-track flex w-max gap-5 py-3"
        >
          {
            [...certificates, ...certificates].map((cert, index) => (
              <AboutCertificate
                index={index}
                name={cert.name}
                logo={cert.logo}
                media={cert.media}
                viewType="marquee"
                issueDate={cert.issueDate}
                length={certificates.length}
                organization={cert.organization}
                credentialID={cert.credentialID}
                credentialURL={cert.credentialURL}
                expirationDate={cert.expirationDate}
              />
            ))
          }
        </div>

        <div
          id="cert-track-grid"
          class="flex w-full gap-5 py-3 flex-wrap hidden"
        >
          {
            certificates.map((cert, index) => (
              <AboutCertificate
                index={index}
                name={cert.name}
                logo={cert.logo}
                media={cert.media}
                viewType="grid"
                issueDate={cert.issueDate}
                length={certificates.length}
                organization={cert.organization}
                credentialID={cert.credentialID}
                credentialURL={cert.credentialURL}
                expirationDate={cert.expirationDate}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="mt-20">
      <div class="mb-8 flex flex-col gap-3 opacity-0 reveal-up">
        <h2
          class="mt-3 text-2xl font-bold text-neutral-900 dark:text-neutral-100 sm:text-3xl"
        >
          Beyond the Screen
        </h2>
        <p
          class="text-xs font-semibold uppercase tracking-[0.28em] text-neutral-500 dark:text-neutral-400"
        >
          Finding inspiration in exploration
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          beyondScreen.map((item, index) => (
            <article class={`opacity-0 reveal-up delay-[${index * 150}ms]`}>
              <div class="relative overflow-hidden rounded-xl border aspect-video border-neutral-200 bg-neutral-100 dark:border-neutral-800 dark:bg-neutral-900 my-10 w-full">
                <VideoPlayer
                  id="about-video"
                  title={item.title}
                  image={item.image}
                  video={item.video}
                />
              </div>
              <h3 class="mt-4 text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
                {item.title}
              </h3>
              <p class="mt-2 text-sm leading-7 text-neutral-600 dark:text-neutral-400">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <div class="opacity-0 reveal-up">
      <LetsConnect />
    </div>
  </section>
</Layout>

<script src="../../assets/js/ship.js"></script>
<script src="../../assets/js/animate-on-scroll.js"></script>
<script src="../../assets/js/certificate-view-button.js"></script>
