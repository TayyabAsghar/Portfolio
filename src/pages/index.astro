---
import { about } from "../data";
import {
  Writings,
  HeroSection,
  Technologies,
  Testimonials,
  PortfolioGrid,
  Main as MainLayout,
} from "../components";

// import SideProjectsGrid from "../components/projects/side-projects-grid.astro";
---

<MainLayout title={about.name}>
  <div
    class="max-w-6xl mx-auto grid grid-cols-1 auto-rows-max gap-28 py-20 lg:py-24"
  >
    <div class="animate-on-scroll reveal">
      <HeroSection />
    </div>

    <div class="animate-on-scroll reveal">
      <Technologies />
    </div>

    <div class="animate-on-scroll reveal">
      <PortfolioGrid count={3} />
    </div>

    <!-- <div class="animate-on-scroll reveal">
      <SideProjectsGrid count={3} />
    </div> -->

    <div class="animate-on-scroll reveal">
      <Testimonials />
    </div>

    <div class="animate-on-scroll reveal">
      <Writings />
    </div>
  </div>

  <script src="../assets/js/animate-on-scroll.js"></script>
</MainLayout>
