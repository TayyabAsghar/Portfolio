---
interface Props {
  audioSrc?: string;
  episode?: string;
  title?: string;
  showName?: string;
  coverImage?: string;
}

const {
  audioSrc = "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3",
  episode = "128",
  title = "Scaling CSS at Heroku with Utility Classes",
  showName = "Full Stack Radio",
  coverImage = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRBHXDRZkxX_3LUt-sJU6URX-rRTYrcIBY7m9Ufq_LqPiam7PJ4aiFxy4nIaDrtGdb3pt0&usqp=CAU",
} = Astro.props;
---

<div
  id="widget-music-player"
  class="static-widget rounded-xl border border-neutral-200 bg-white shadow-lg shadow-neutral-200/70 dark:border-neutral-800 dark:bg-neutral-900 dark:shadow-black/40"
>
  <audio id="podcast-audio" src={audioSrc} preload="metadata"></audio>

  <div
    class="space-y-6 p-4 pb-6 sm:space-y-8 sm:p-10 sm:pb-8 lg:space-y-6 lg:p-6 xl:space-y-8 xl:p-10 xl:pb-8"
  >
    <div class="flex items-center space-x-4">
      <img
        src={coverImage}
        alt={showName}
        width="88"
        height="88"
        class="flex-none rounded-lg bg-neutral-100 dark:bg-neutral-800"
        loading="lazy"
      />
      <div class="min-w-0 flex-auto space-y-1 font-semibold">
        <p class="text-sm leading-6 text-neutral-600 dark:text-neutral-300">
          <abbr title="Episode">Ep.</abbr>
          {episode}
        </p>
        <h2
          class="truncate text-sm leading-6 text-neutral-500 dark:text-neutral-400"
        >
          {title}
        </h2>
        <p class="text-lg text-neutral-900 dark:text-neutral-100">{showName}</p>
      </div>
    </div>

    <div class="space-y-2">
      <div class="relative">
        <div
          class="overflow-hidden rounded-full bg-neutral-100 dark:bg-neutral-800"
        >
          <div
            id="audio-progress"
            class="h-2 w-0 bg-neutral-900 dark:bg-neutral-200"
            role="progressbar"
            aria-label="music progress"
            aria-valuenow="0"
            aria-valuemin="0"
            aria-valuemax="100"
          >
          </div>
        </div>
        <div
          id="audio-thumb"
          class="absolute left-0 top-1/2 -ml-2 -mt-2 flex h-4 w-4 items-center justify-center rounded-full bg-white ring-2 ring-neutral-900 shadow dark:bg-neutral-100 dark:ring-neutral-200"
        >
          <div
            class="h-1.5 w-1.5 rounded-full bg-neutral-900 ring-1 ring-inset ring-neutral-900/10 dark:bg-neutral-700"
          >
          </div>
        </div>
      </div>
      <div
        class="flex justify-between text-sm font-medium leading-6 tabular-nums"
      >
        <div id="audio-current" class="text-neutral-900 dark:text-neutral-100">
          00:00
        </div>
        <div id="audio-duration" class="text-neutral-500 dark:text-neutral-400">
          00:00
        </div>
      </div>
    </div>
  </div>

  <div
    class="flex items-center rounded-b-xl bg-neutral-50 px-4 py-3 text-neutral-500 dark:bg-neutral-800 dark:text-neutral-300"
  >
    <div class="flex flex-auto items-center justify-evenly gap-2">
      <button
        type="button"
        id="rewind-10"
        title="Back 10 seconds"
        aria-label="Back 10 seconds"
        class="transition hover:text-neutral-800 dark:hover:text-neutral-100"
      >
        <svg width="24" height="24" fill="none">
          <path
            d="M6.492 16.95c2.861 2.733 7.5 2.733 10.362 0 2.861-2.734 2.861-7.166 0-9.9-2.862-2.733-7.501-2.733-10.362 0A7.096 7.096 0 0 0 5.5 8.226"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
          </path>
          <path
            d="M5 5v3.111c0 .491.398.889.889.889H9"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
          </path>
        </svg>
      </button>

      <button
        type="button"
        id="stop-audio"
        title="Stop"
        aria-label="Stop playback"
        class="transition hover:text-neutral-800 dark:hover:text-neutral-100"
      >
        <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
          <rect x="6" y="6" width="12" height="12" rx="2"></rect>
        </svg>
      </button>
    </div>

    <button
      type="button"
      id="play-pause"
      class="mx-auto flex h-16 w-16 flex-none items-center justify-center rounded-full bg-neutral-900 text-neutral-100 ring-1 ring-neutral-900/10 shadow-md transition hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300"
      aria-label="Play"
      title="Play / Pause"
    >
      <svg
        id="icon-play"
        width="30"
        height="32"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d="M8 5v14l11-7z"></path>
      </svg>
      <svg
        id="icon-pause"
        width="30"
        height="32"
        fill="currentColor"
        class="hidden"
      >
        <rect x="6" y="4" width="4" height="24" rx="2"></rect>
        <rect x="20" y="4" width="4" height="24" rx="2"></rect>
      </svg>
    </button>

    <div class="flex flex-auto items-center justify-evenly gap-2">
      <button
        type="button"
        id="forward-10"
        title="Forward 10 seconds"
        aria-label="Forward 10 seconds"
        class="transition hover:text-neutral-800 dark:hover:text-neutral-100"
      >
        <svg width="24" height="24" fill="none">
          <path
            d="M17.509 16.95c-2.862 2.733-7.501 2.733-10.363 0-2.861-2.734-2.861-7.166 0-9.9 2.862-2.733 7.501-2.733 10.363 0 .38.365.711.759.991 1.176"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
          </path>
          <path
            d="M19 5v3.111c0 .491-.398.889-.889.889H15"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
          </path>
        </svg>
      </button>
      <div
        class="rounded-lg px-2 text-xs font-semibold leading-6 text-neutral-600 ring-2 ring-inset ring-neutral-400 dark:bg-neutral-700 dark:text-neutral-200 dark:ring-neutral-600"
      >
        10s
      </div>
    </div>
  </div>
</div>

<script>
  const root = document.getElementById("widget-music-player");
  if (root) {
    const audio = root.querySelector("#podcast-audio");
    const playPauseButton = root.querySelector("#play-pause");
    const stopButton = root.querySelector("#stop-audio");
    const rewindButton = root.querySelector("#rewind-10");
    const forwardButton = root.querySelector("#forward-10");
    const currentTimeEl = root.querySelector("#audio-current");
    const durationEl = root.querySelector("#audio-duration");
    const progressEl = root.querySelector("#audio-progress");
    const thumbEl = root.querySelector("#audio-thumb");
    const playIcon = root.querySelector("#icon-play");
    const pauseIcon = root.querySelector("#icon-pause");

    const formatTime = (seconds) => {
      if (!Number.isFinite(seconds)) return "00:00";
      const mins = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${String(mins).padStart(2, "0")}:${String(secs).padStart(2, "0")}`;
    };

    const updateTimeline = () => {
      if (!audio || !progressEl || !thumbEl || !currentTimeEl || !durationEl)
        return;

      const duration = audio.duration || 0;
      const currentTime = audio.currentTime || 0;
      const percent = duration > 0 ? (currentTime / duration) * 100 : 0;

      progressEl.style.width = `${percent}%`;
      progressEl.setAttribute("aria-valuenow", String(Math.round(percent)));
      thumbEl.style.left = `${percent}%`;
      currentTimeEl.textContent = formatTime(currentTime);
      durationEl.textContent = formatTime(duration);
    };

    const updatePlayState = () => {
      if (!audio || !playPauseButton || !playIcon || !pauseIcon) return;
      const isPlaying = !audio.paused;
      playPauseButton.setAttribute("aria-label", isPlaying ? "Pause" : "Play");
      playIcon.classList.toggle("hidden", isPlaying);
      pauseIcon.classList.toggle("hidden", !isPlaying);
    };

    if (audio) {
      audio.addEventListener("loadedmetadata", updateTimeline);
      audio.addEventListener("timeupdate", updateTimeline);
      audio.addEventListener("play", updatePlayState);
      audio.addEventListener("pause", updatePlayState);
      audio.addEventListener("ended", () => {
        audio.currentTime = 0;
        updateTimeline();
        updatePlayState();
      });
    }

    playPauseButton?.addEventListener("click", () => {
      if (!audio) return;
      if (audio.paused) {
        audio.play();
      } else {
        audio.pause();
      }
    });

    stopButton?.addEventListener("click", () => {
      if (!audio) return;
      audio.pause();
      audio.currentTime = 0;
      updateTimeline();
      updatePlayState();
    });

    rewindButton?.addEventListener("click", () => {
      if (!audio) return;
      audio.currentTime = Math.max(0, audio.currentTime - 10);
      updateTimeline();
    });

    forwardButton?.addEventListener("click", () => {
      if (!audio) return;
      const duration = Number.isFinite(audio.duration)
        ? audio.duration
        : audio.currentTime + 10;
      audio.currentTime = Math.min(duration, audio.currentTime + 10);
      updateTimeline();
    });

    updateTimeline();
    updatePlayState();
  }
</script>
