---
interface Track {
  title: string;
  website: string;
  showName: string;
  audioSrc: string;
  coverImage: string;
  episode?: string;
}

interface Props {
  tracks: Track[];
  initialIndex?: number;
}

const { tracks = [], initialIndex = 0 } = Astro.props;
const safeInitialIndex = Math.min(Math.max(initialIndex, 0), tracks.length - 1);
const activeTrack = tracks[safeInitialIndex];
---

<div
  data-audio-player
  id="widget-music-player"
  data-tracks={JSON.stringify(tracks)}
  data-initial-index={safeInitialIndex}
  class="static-widget rounded-xl border border-neutral-200 bg-white shadow-lg shadow-neutral-200/70 dark:border-neutral-800 dark:bg-neutral-900 dark:shadow-black/40"
>
  <audio id="podcast-audio" src={activeTrack.audioSrc} preload="metadata"
  ></audio>

  <div
    class="space-y-6 p-4 pb-6 sm:space-y-8 sm:p-10 sm:pb-8 lg:space-y-6 lg:p-6 xl:space-y-8 xl:p-10 xl:pb-8"
  >
    <div class="flex items-center space-x-4">
      <img
        width="88"
        height="88"
        loading="lazy"
        id="track-cover"
        alt={activeTrack.showName}
        src={activeTrack.coverImage}
        class="rounded-lg bg-neutral-100 object-cover dark:bg-neutral-800"
      />
      <div class="min-w-0 flex-auto space-y-1 font-semibold">
        <p class="text-sm leading-6 text-neutral-600 dark:text-neutral-300">
          Ep.
          <span id="track-episode">{activeTrack.episode}</span>
        </p>
        <div class="marquee">
          <h2
            class="marquee-content marquee-animation text-sm leading-6 text-neutral-500 dark:text-neutral-400"
          >
            <span id="track-title" class="marquee-text">
              {activeTrack.title}
            </span>

            <span aria-hidden="true" class="marquee-text marquee-copy">
              {activeTrack.title}
            </span>
          </h2>
        </div>
        <a
          id="track-link"
          target="_blank"
          rel="noopener noreferrer"
          href={activeTrack.website}
          aria-label={`Open ${activeTrack.showName} episode`}
          class="block flex-none rounded-lg focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500"
        >
          <div class="marquee">
            <p
              class="marquee-content marquee-animation text-lg text-neutral-900 dark:text-neutral-100"
            >
              <span id="track-show" class="marquee-text">
                {activeTrack.showName}
              </span>

              <span aria-hidden="true" class="marquee-text marquee-copy">
                {activeTrack.showName}
              </span>
            </p>
          </div>
        </a>
      </div>
    </div>

    <div class="space-y-2">
      <div class="relative h-5">
        <div
          class="absolute inset-x-0 top-1/2 h-2 -translate-y-1/2 overflow-hidden rounded-full bg-neutral-100 dark:bg-neutral-800"
        >
          <div
            data-part="audio-progress"
            class="h-full w-0 rounded-full bg-neutral-900 dark:bg-neutral-200"
          >
          </div>
        </div>

        <input
          min="0"
          max="0"
          value="0"
          step="0.1"
          type="range"
          id="seek-bar"
          aria-label="Seek audio"
          class="seek-slider absolute inset-x-0 top-1/2 h-5 w-full -translate-y-1/2 cursor-pointer appearance-none bg-transparent"
        />

        <div
          data-part="seek-preview"
          class="pointer-events-none absolute -top-6 hidden -translate-x-1/2 rounded-md bg-neutral-900 px-1.5 py-0.5 text-[10px] font-medium text-neutral-100 dark:bg-neutral-100 dark:text-neutral-900"
        >
          00:00
        </div>
      </div>

      <div
        class="flex justify-between text-sm font-medium leading-6 tabular-nums"
      >
        <div id="audio-current" class="text-neutral-900 dark:text-neutral-100">
          00:00
        </div>
        <div id="audio-duration" class="text-neutral-500 dark:text-neutral-400">
          00:00
        </div>
      </div>
    </div>
  </div>

  <div
    class="flex items-center gap-2 rounded-b-xl bg-neutral-50 px-4 py-3 text-neutral-500 dark:bg-neutral-800 dark:text-neutral-300"
  >
    <div class="flex flex-auto items-center justify-evenly gap-1">
      <button
        type="button"
        id="prev-track"
        title="Previous audio"
        aria-label="Previous audio"
        class="rounded-md p-2 transition hover:bg-neutral-200 hover:text-neutral-800 dark:hover:bg-neutral-700 dark:hover:text-neutral-100"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M6 6h2v12H6zM18.5 18l-8-6 8-6z"></path>
        </svg>
      </button>

      <button
        type="button"
        id="rewind-10"
        title="Back 10 seconds"
        aria-label="Back 10 seconds"
        class="rounded-md px-2 py-1 transition hover:bg-neutral-200 hover:text-neutral-800 dark:hover:bg-neutral-700 dark:hover:text-neutral-100"
      >
        <span class="flex flex-col items-center leading-none">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M6.5 8.5A8 8 0 1 1 4 14"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
            <path
              d="M4 8v4h4"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span class="text-[10px] font-semibold">-10s</span>
        </span>
      </button>
    </div>

    <button
      type="button"
      id="play-pause"
      class="mx-auto flex h-16 w-16 flex-none items-center justify-center rounded-full bg-neutral-900 text-neutral-100 ring-1 ring-neutral-900/10 shadow-md transition hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300"
      aria-label="Play"
      title="Play / Pause"
    >
      <svg
        id="icon-play"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M8 5v14l11-7z"></path>
      </svg>
      <svg
        id="icon-pause"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="hidden"
        aria-hidden="true"
      >
        <rect x="7" y="5" width="3.5" height="14" rx="1.5"></rect>
        <rect x="13.5" y="5" width="3.5" height="14" rx="1.5"></rect>
      </svg>
    </button>

    <div class="flex flex-auto items-center justify-evenly gap-1">
      <button
        type="button"
        id="forward-10"
        title="Forward 10 seconds"
        aria-label="Forward 10 seconds"
        class="rounded-md px-2 py-1 transition hover:bg-neutral-200 hover:text-neutral-800 dark:hover:bg-neutral-700 dark:hover:text-neutral-100"
      >
        <span class="flex flex-col items-center leading-none">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M17.5 8.5A8 8 0 1 0 20 14"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
            <path
              d="M20 8v4h-4"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span class="text-[10px] font-semibold">+10s</span>
        </span>
      </button>

      <button
        type="button"
        id="next-track"
        title="Next audio"
        aria-label="Next audio"
        class="rounded-md p-2 transition hover:bg-neutral-200 hover:text-neutral-800 dark:hover:bg-neutral-700 dark:hover:text-neutral-100"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M16 6h2v12h-2zM5.5 18l8-6-8-6z"></path>
        </svg>
      </button>

      <label class="sr-only" for="playback-rate">Playback speed</label>
      <div class="relative" data-speed-dropdown>
        <button
          type="button"
          id="playback-rate"
          title="Playback speed"
          aria-haspopup="listbox"
          aria-expanded="false"
          class="min-w-[5.25rem] rounded-full border border-neutral-200 bg-neutral-100/90 py-2 pl-3 pr-8 text-left text-xs font-semibold tracking-[0.02em] text-neutral-700 outline-none transition hover:border-neutral-300 hover:bg-white focus:border-neutral-400 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100 dark:hover:border-neutral-600 dark:hover:bg-neutral-800"
        >
          <span id="playback-rate-label">1.0x</span>
        </button>
        <svg
          aria-hidden="true"
          viewBox="0 0 20 20"
          fill="none"
          class="pointer-events-none absolute right-3 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-neutral-500 dark:text-neutral-400"
        >
          <path
            d="M6 8l4 4 4-4"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <div
          id="playback-rate-menu"
          role="listbox"
          aria-label="Playback speed options"
          class="absolute right-0 top-[calc(100%+0.5rem)] z-20 hidden min-w-[7rem] rounded-2xl border border-neutral-200 bg-white p-1.5 shadow-[0_18px_40px_-20px_rgba(23,23,23,0.35)] dark:border-neutral-700 dark:bg-neutral-900 dark:shadow-[0_20px_45px_-24px_rgba(0,0,0,0.6)]"
        >
          <button
            type="button"
            role="option"
            data-rate-option
            data-rate="1"
            aria-selected="true"
            class="flex w-full items-center justify-between rounded-xl px-3 py-2 text-xs font-semibold text-neutral-700 transition hover:bg-neutral-100 dark:text-neutral-100 dark:hover:bg-neutral-800"
          >
            <span>1.0x</span>
            <span class="text-[10px] text-neutral-400 dark:text-neutral-500"
              >Normal</span
            >
          </button>
          <button
            type="button"
            role="option"
            data-rate-option
            data-rate="1.25"
            aria-selected="false"
            class="flex w-full items-center justify-between rounded-xl px-3 py-2 text-xs font-semibold text-neutral-700 transition hover:bg-neutral-100 dark:text-neutral-100 dark:hover:bg-neutral-800"
          >
            <span>1.25x</span>
            <span class="text-[10px] text-neutral-400 dark:text-neutral-500"
              >Steady</span
            >
          </button>
          <button
            type="button"
            role="option"
            data-rate-option
            data-rate="1.5"
            aria-selected="false"
            class="flex w-full items-center justify-between rounded-xl px-3 py-2 text-xs font-semibold text-neutral-700 transition hover:bg-neutral-100 dark:text-neutral-100 dark:hover:bg-neutral-800"
          >
            <span>1.5x</span>
            <span class="text-[10px] text-neutral-400 dark:text-neutral-500"
              >Fast</span
            >
          </button>
          <button
            type="button"
            role="option"
            data-rate-option
            data-rate="1.75"
            aria-selected="false"
            class="flex w-full items-center justify-between rounded-xl px-3 py-2 text-xs font-semibold text-neutral-700 transition hover:bg-neutral-100 dark:text-neutral-100 dark:hover:bg-neutral-800"
          >
            <span>1.75x</span>
            <span class="text-[10px] text-neutral-400 dark:text-neutral-500"
              >Quick</span
            >
          </button>
          <button
            type="button"
            role="option"
            data-rate-option
            data-rate="2"
            aria-selected="false"
            class="flex w-full items-center justify-between rounded-xl px-3 py-2 text-xs font-semibold text-neutral-700 transition hover:bg-neutral-100 dark:text-neutral-100 dark:hover:bg-neutral-800"
          >
            <span>2.0x</span>
            <span class="text-[10px] text-neutral-400 dark:text-neutral-500"
              >Max</span
            >
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="../../assets/js/music-player.js"></script>
