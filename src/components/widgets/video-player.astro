---
interface Props {
  id: string;
  title: string;
  video: string;
  image: string;
  sound?: string;
  volume?: number;
  overlay?: boolean;
}

const { id, title, video, image, sound, volume = 1, overlay } = Astro.props;
---

<>
  <img
    alt={title}
    src={image}
    id={`${id}-poster`}
    class="absolute inset-0 z-20 h-full w-full object-cover transition-opacity duration-500"
  />

  <div class="absolute inset-0 z-30">
    <video
      loop
      muted
      autoplay
      playsinline
      preload="metadata"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500"
      oncanplay="this.classList.remove('opacity-0'); document.getElementById(`${id}-poster`)?.classList.add('opacity-0')"
    >
      <source src={video} type="video/mp4" />
    </video>

    {
      overlay && (
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-black/40 to-black/10 dark:hidden" />
      )
    }

    {
      !!sound && (
        <div class="hidden">
          <audio id={`${id}-sound-a`} data-volume={volume} loop>
            <source src={sound} type="audio/wav" />
          </audio>
          <audio id={`${id}-sound-b`} data-volume={volume} loop>
            <source src={sound} type="audio/wav" />
          </audio>
        </div>
      )
    }
  </div>

  <script define:vars={{ id }}>
    const audioA = document.getElementById(`${id}-sound-a`);
    const audioB = document.getElementById(`${id}-sound-b`);
    const videoContainer = document.getElementById(
      `${id}-poster`,
    )?.parentElement;
    if (!audioA || !audioB || !videoContainer) return;

    const volume = parseFloat(audioA.dataset.volume || "1");
    audioA.volume = volume;
    audioB.volume = 0;

    let activeAudio = audioA;
    let passiveAudio = audioB;
    let isFading = false;
    const fadeDuration = 0.5;

    const fadeLoop = () => {
      if (isFading) return;
      const currentTime = activeAudio.currentTime;
      const duration = activeAudio.duration || 0;
      const timeUntilEnd = duration - currentTime;

      if (timeUntilEnd <= fadeDuration && timeUntilEnd > 0) {
        isFading = true;

        passiveAudio.currentTime = 0;
        passiveAudio.volume = volume;
        passiveAudio.play().catch(() => {});

        const fadeInterval = setInterval(() => {
          const remaining = activeAudio.duration - activeAudio.currentTime;
          const progress = 1 - remaining / fadeDuration;

          const easedProgress = progress * progress * (3 - 2 * progress);

          activeAudio.volume = volume * (1 - easedProgress);
          passiveAudio.volume = volume * easedProgress;

          if (progress >= 1) {
            clearInterval(fadeInterval);
            activeAudio.pause();
            activeAudio.currentTime = 0;

            [activeAudio, passiveAudio] = [passiveAudio, activeAudio];
            isFading = false;
          }
        }, 16);
      }
    };

    activeAudio.addEventListener("timeupdate", fadeLoop);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) activeAudio.play().catch(() => {});
          else {
            activeAudio.pause();
            passiveAudio.pause();
          }
        });
      },
      { threshold: 0.3 },
    );

    observer.observe(videoContainer);

    let isTabVisible = true;

    const handleVisibilityChange = () => {
      if (document.hidden) {
        activeAudio.pause();
        passiveAudio.pause();
        isTabVisible = false;
      } else {
        const shouldPlay =
          videoContainer.getBoundingClientRect().top >=
          -videoContainer.offsetHeight * 0.3;
        if (shouldPlay) activeAudio.play().catch(() => {});

        isTabVisible = true;
      }
    };

    document.addEventListener("visibilitychange", handleVisibilityChange);
  </script>
</>
