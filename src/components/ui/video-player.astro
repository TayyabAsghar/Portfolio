---
interface Props {
  id: string;
  title: string;
  video: string;
  image: string;
  sound?: string;
  volume?: number;
  overlay?: boolean;
}

const { id, title, video, image, sound, volume = 1, overlay } = Astro.props;
---

<div id={`${id}-player`} class="absolute inset-0">
  <img
    alt={title}
    src={image}
    id={`${id}-poster`}
    class="absolute inset-0 z-20 h-full w-full object-cover transition-opacity duration-500"
  />

  <div class="absolute inset-0 z-30">
    <video
      loop
      muted
      autoplay
      playsinline
      preload="metadata"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500"
      oncanplay="this.classList.remove('opacity-0'); document.getElementById(`${id}-poster`)?.classList.add('opacity-0')"
    >
      <source src={video} type="video/mp4" />
    </video>

    {
      overlay && (
        <div class="pointer-events-none absolute inset-0 bg-linear-to-b from-black/40 to-black/10 dark:hidden" />
      )
    }

    {
      !!sound && (
        <div class="hidden">
          <audio id={`${id}-sound-a`} data-volume={volume} loop>
            <source src={sound} type="audio/wav" />
          </audio>
          <audio id={`${id}-sound-b`} data-volume={volume} loop>
            <source src={sound} type="audio/wav" />
          </audio>
        </div>
      )
    }
  </div>

  {
    !!sound && (
      <script is:inline define:vars={{ id }}>
        const audioA = document.getElementById(`${id}-sound-a`);
        const audioB = document.getElementById(`${id}-sound-b`);
        const videoContainer = document.getElementById(`${id}-player`);

        if (audioA && audioB && videoContainer) {
          const volume = parseFloat(audioA.dataset.volume || "1");
          const fadeDuration = 0.5;
          const fadeIntervals = new Set();

          let activeAudio = audioA;
          let passiveAudio = audioB;
          let isFading = false;
          let isInView = false;
          let isDisposed = false;

          audioA.volume = volume;
          audioB.volume = 0;

          const stopFadeIntervals = () => {
            fadeIntervals.forEach((intervalId) => clearInterval(intervalId));
            fadeIntervals.clear();
            isFading = false;
          };

          const pauseAll = () => {
            stopFadeIntervals();
            audioA.pause();
            audioB.pause();
          };

          const shouldPlay = () =>
            isInView &&
            !isDisposed &&
            !document.hidden &&
            document.hasFocus();

          const syncPlayback = () => {
            if (!shouldPlay()) {
              pauseAll();
              return;
            }

            activeAudio.play().catch(() => {});
          };

          const fadeLoop = () => {
            if (isFading || !shouldPlay()) return;

            const duration = activeAudio.duration || 0;
            const timeUntilEnd = duration - activeAudio.currentTime;

            if (timeUntilEnd <= fadeDuration && timeUntilEnd > 0) {
              isFading = true;
              passiveAudio.currentTime = 0;
              passiveAudio.volume = 0;
              passiveAudio.play().catch(() => {});

              const fadeInterval = setInterval(() => {
                if (!shouldPlay()) {
                  pauseAll();
                  return;
                }

                const remaining = activeAudio.duration - activeAudio.currentTime;
                const progress = Math.min(1, 1 - remaining / fadeDuration);
                const easedProgress = progress * progress * (3 - 2 * progress);

                activeAudio.volume = volume * (1 - easedProgress);
                passiveAudio.volume = volume * easedProgress;

                if (progress >= 1) {
                  clearInterval(fadeInterval);
                  fadeIntervals.delete(fadeInterval);
                  activeAudio.pause();
                  activeAudio.currentTime = 0;
                  activeAudio.volume = 0;

                  [activeAudio, passiveAudio] = [passiveAudio, activeAudio];
                  activeAudio.volume = volume;
                  passiveAudio.volume = 0;
                  isFading = false;
                }
              }, 16);

              fadeIntervals.add(fadeInterval);
            }
          };

          audioA.addEventListener("timeupdate", fadeLoop);
          audioB.addEventListener("timeupdate", fadeLoop);

          const observer = new IntersectionObserver(
            ([entry]) => {
              isInView = !!entry?.isIntersecting;
              syncPlayback();
            },
            { threshold: 0.3 },
          );

          observer.observe(videoContainer);

          const dispose = () => {
            isDisposed = true;
            observer.disconnect();
            pauseAll();
            audioA.removeEventListener("timeupdate", fadeLoop);
            audioB.removeEventListener("timeupdate", fadeLoop);
            document.removeEventListener("visibilitychange", syncPlayback);
            window.removeEventListener("focus", syncPlayback);
            window.removeEventListener("blur", pauseAll);
            window.removeEventListener("pagehide", dispose);
            document.removeEventListener("astro:before-swap", dispose);
          };

          document.addEventListener("visibilitychange", syncPlayback);
          window.addEventListener("focus", syncPlayback);
          window.addEventListener("blur", pauseAll);
          window.addEventListener("pagehide", dispose);
          document.addEventListener("astro:before-swap", dispose, { once: true });
        }
      </script>
    )
  }
</div>
