---
interface Props {
  path: string;
  duration?: number;
}

const { path, duration } = Astro.props;
---

<div class="hidden" data-sound-path={path} data-target-duration={duration}>
</div>

<script>
  const audioBlobUrls = new Map();
  const audioRequests = new Map();

  const getAudioUrl = async (path: string) => {
    if (audioBlobUrls.has(path)) return audioBlobUrls.get(path);
    if (audioRequests.has(path)) return audioRequests.get(path);

    const promise = fetch(path)
      .then((res) => {
        if (!res.ok)
          throw new Error(`Failed to fetch audio: ${res.statusText}`);
        return res.blob();
      })
      .then((blob) => {
        const url = URL.createObjectURL(blob);
        audioBlobUrls.set(path, url);
        return url;
      })
      .catch((err) => {
        console.error("Audio cache error:", err);
        audioRequests.delete(path);
        return path;
      });

    audioRequests.set(path, promise);
    return promise;
  };

  const initHoverSounds = () => {
    const soundContainers = document.querySelectorAll("[data-sound-path]");

    soundContainers.forEach(async (container) => {
      const parent = container.closest(".group");
      if (!parent || parent.hasAttribute("data-sound-processed")) return;
      parent.setAttribute("data-sound-processed", "true");

      const path = container.getAttribute("data-sound-path");
      const targetDurationMs = container.getAttribute("data-target-duration");

      if (!path) return;

      const audioSource = await getAudioUrl(path);
      const audio = new Audio(audioSource);
      audio.preload = "auto";

      const setupPlaybackRate = () => {
        if (targetDurationMs && audio.duration) {
          const targetDurationSec = parseFloat(targetDurationMs) / 1000;
          audio.playbackRate = audio.duration / targetDurationSec;
        }
      };

      audio.addEventListener("loadedmetadata", setupPlaybackRate);

      parent.addEventListener("mouseenter", () => {
        audio.currentTime = 0;
        audio.play().catch((e) => console.error("Audio play failed:", e));
      });

      parent.addEventListener("mouseleave", () => {
        audio.pause();
        audio.currentTime = 0;
      });
    });
  };

  initHoverSounds();

  document.addEventListener("astro:page-load", initHoverSounds);
</script>
