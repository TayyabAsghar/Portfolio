---
interface Props {
  text: string;
  class?: string;
  loop?: boolean;
  loopDelay?: number;
  [key: string]: any;
}

const {
  text,
  loop = false,
  class: className,
  loopDelay = 3000,
  ...rest
} = Astro.props;
---

<span
  class="typewriter-effect inline-grid py-2 align-bottom"
  data-text={text}
  aria-label={text}
  data-loop={loop.toString()}
  data-loop-delay={loopDelay.toString()}
  {...rest}
>
  <span
    aria-hidden="true"
    class={`invisible col-start-1 row-start-1 whitespace-nowrap ${className || ""}`}
  >
    {text}
  </span>
  <span
    data-typewriter-text
    class={`col-start-1 row-start-1 inline-block overflow-hidden whitespace-nowrap ${className || ""}`}
  >
  </span>
</span>

<script>
  // @ts-nocheck
  const typewriterTimers = new WeakMap();

  const initTypewriter = () => {
    const elements = document.querySelectorAll(".typewriter-effect");

    elements.forEach((element) => {
      if (element.hasAttribute("data-processed")) return;
      element.setAttribute("data-processed", "true");

      const textElement = element.querySelector("[data-typewriter-text]");
      if (!(textElement instanceof HTMLElement)) return;

      const text = element.getAttribute("data-text") || "";
      const isLoop = element.getAttribute("data-loop") === "true";
      const loopDelay = parseInt(
        element.getAttribute("data-loop-delay") || "3000",
      );
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (prefersReducedMotion) {
        textElement.textContent = text;
        return;
      }

      const typeSpeed = 85;
      const deleteSpeed = 35;
      const timers = [];

      const queue = (callback, delay) => {
        const timer = window.setTimeout(callback, delay);
        timers.push(timer);
      };

      typewriterTimers.set(element, timers);

      const typeText = (index = 0) => {
        textElement.style.opacity = "1";
        textElement.textContent = text.slice(0, index);

        if (index < text.length) {
          queue(() => typeText(index + 1), typeSpeed);
          return;
        }

        if (isLoop) {
          queue(() => deleteText(text.length), loopDelay);
        }
      };

      const deleteText = (index) => {
        textElement.textContent = text.slice(0, index);

        if (index > 0) {
          queue(() => deleteText(index - 1), deleteSpeed);
          return;
        }

        queue(() => typeText(0), 450);
      };

      typeText(0);
    });
  };

  initTypewriter();

  document.addEventListener("astro:page-load", initTypewriter);

  document.addEventListener("astro:before-swap", () => {
    document.querySelectorAll("[data-processed]").forEach((el) => {
      typewriterTimers.get(el)?.forEach((timer) => window.clearTimeout(timer));
      typewriterTimers.delete(el);
      el.removeAttribute("data-processed");
    });
  });
</script>
