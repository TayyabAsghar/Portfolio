---
import { HoverSound } from "../ui";

interface Props {
  path?: string;
  class?: string;
  strokeColor?: string;
  animationDuration?: number;
  strokeWidth?: number | string;
}

const {
  path,
  class: className,
  strokeWidth = "1.5",
  animationDuration = 0.8,
  strokeColor = "text-neutral-300 dark:text-neutral-700",
} = Astro.props;

const svgPath =
  path ??
  "M1.24036 76.0361C4.98132 80.8509 8.4624 85.9984 12.7094 90.3889C14.6359 92.3805 18.3264 96.01 21.5419 95.5137C25.2559 94.9404 25.8658 89.7124 25.9911 86.846C26.2416 81.1141 24.2378 75.7533 22.3658 70.4334C21.9386 69.2195 15.3676 53.9587 19.2678 53.6253C22.8205 53.3217 26.9587 56.6217 29.4516 58.7337C35.1397 63.5528 39.8018 69.548 45.0402 74.8332C47.47 77.2846 50.2141 79.7113 53.4113 81.1115C55.9035 82.203 55.7491 80.4296 55.537 78.1783C55.108 73.6239 53.2346 69.5125 51.302 65.424C48.15 58.7556 44.6601 52.2258 40.9865 45.831C34.9764 35.3691 28.4472 25.2078 22.6789 14.6042C22.5746 14.4126 19.7858 10.0821 20.7179 9.56182C21.6406 9.04688 24.8604 11.4501 25.0188 11.5557C29.515 14.5532 33.5695 18.1495 37.4271 21.9207C50.7896 34.9837 61.9845 50.1954 75.7232 62.8863C76.6062 63.7019 84.6288 72.0049 86.5331 70.2686C88.0573 68.8789 85.1903 62.7083 84.704 61.535C82.7828 56.9001 80.1308 52.6814 77.6347 48.3522C76.572 46.5091 74.8799 44.1797 74.5697 42.008C74.346 40.4425 77.9359 42.5552 78.3103 42.7495C79.8405 43.5437 87.8202 49.851 88.8401 46.6714C89.7984 43.6836 88.0929 39.8222 87.2581 37.015C86.2423 33.5988 84.5193 30.0286 84.0943 26.4688C83.3273 20.0457 93.6924 23.7268 96.6179 24.1783C99.5214 24.6263 103.147 25.2887 103.308 21.3604C103.595 14.3801 100.486 7.60974 97.9362 1.28961";
---

<>
  <HoverSound
    duration={animationDuration}
    path="/assets/sounds/home/writing.wav"
  />

  <div
    class={`absolute inset-0 w-full h-full pointer-events-none -z-10 ${className || ""}`}
    data-duration={animationDuration}
  >
    <svg
      role="img"
      width="274"
      height="183"
      viewBox="0 0 274 183"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-label="Rough pencil scribble like quick handwritten mark"
      class={`opacity-0 group-hover:opacity-100 transition-opacity duration-300 ${strokeColor}`}
    >
      <g filter="url(#soften)">
        <path
          d={svgPath}
          fill="none"
          fill="transparent"
          stroke="currentColor"
          stroke-linecap="round"
          filter="url(#roughen)"
          stroke-linejoin="round"
          class="hover-pencil-path"
          stroke-width={strokeWidth}
          vector-effect="non-scaling-stroke"
        >
        </path>
      </g>
    </svg>
  </div>
</>

<script>
  import { animate } from "motion";

  const initPencilAnimations = () => {
    const paths = document.querySelectorAll(
      ".hover-pencil-path",
    ) as NodeListOf<SVGPathElement>;
    paths.forEach((path) => {
      const parent = path.closest(".group");
      const wrapperElement = path.closest("div[data-duration]");
      if (!parent || parent.hasAttribute("data-pencil-processed")) return;
      parent.setAttribute("data-pencil-processed", "true");

      let durationVal = parseFloat(
        wrapperElement?.getAttribute("data-duration") || "0.8",
      );

      if (durationVal > 100) durationVal = durationVal / 1000;

      animate(path, { pathLength: 0 }, { duration: 0 });

      let currentAnim: any;

      parent.addEventListener("mouseenter", () => {
        if (currentAnim) currentAnim.stop();

        currentAnim = animate(
          path,
          { pathLength: [0, 1] },
          {
            ease: "easeOut",
            duration: durationVal,
          },
        );
      });

      parent.addEventListener("mouseleave", () => {
        if (currentAnim) currentAnim.stop();

        currentAnim = animate(
          path,
          { pathLength: 0 },
          {
            ease: "easeIn",
            duration: durationVal * 0.6,
          },
        );
      });
    });
  };

  initPencilAnimations();

  document.addEventListener("astro:page-load", initPencilAnimations);

  document.addEventListener("astro:before-swap", () => {
    document.querySelectorAll("[data-pencil-processed]").forEach((el) => {
      el.removeAttribute("data-pencil-processed");
    });
  });
</script>
