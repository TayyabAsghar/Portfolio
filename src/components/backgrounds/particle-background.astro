---
export interface Props {
  density?: number;
  cwColorClass?: string;
  ccwColorClass?: string;
  direction?: "clockwise" | "counter-clockwise" | "both";
}

const {
  density = 1,
  direction = "both",
  cwColorClass = "bg-neutral-900/60 dark:bg-indigo-400/60 shadow-[0_0_8px_rgba(0,0,0,0.25)] dark:shadow-[0_0_8px_rgba(129,140,248,0.5)]",
  ccwColorClass = "bg-neutral-800/50 dark:bg-fuchsia-400/40 blur-[1px]",
} = Astro.props;

const cwCount = Math.floor(80 * density);
const ccwCount = Math.floor(60 * density);

const showCW = direction === "both" || direction === "clockwise";
const showCCW = direction === "both" || direction === "counter-clockwise";
---

<div
  class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[250vw] h-[250vw] md:w-375 md:h-375 z-0 pointer-events-none"
>
  {
    showCW &&
      [
        { speedClass: "animate-[spin_50s_linear_infinite]" },
        { speedClass: "animate-[spin_90s_linear_infinite]" },
        { speedClass: "animate-[spin_130s_linear_infinite]" },
      ].map((layer) => (
        <div
          class={`absolute inset-0 w-full h-full origin-center ${layer.speedClass}`}
        >
          {Array.from({ length: Math.ceil(cwCount / 3) }).map(() => {
            const r = 100 + Math.random() * 800;
            const angle = Math.random() * 360;
            const size = Math.random() * 3 + 1;
            const opacity = Math.random() * 0.4 + 0.15;
            const delay = Math.random() * 5;
            return (
              <div
                class={`absolute rounded-full animate-pulse transition-all ${cwColorClass}`}
                style={`top: calc(50% + ${Math.sin((angle * Math.PI) / 180) * r}px); left: calc(50% + ${Math.cos((angle * Math.PI) / 180) * r}px); width: ${size}px; height: ${size}px; opacity: ${opacity}; animation-duration: ${2 + Math.random() * 3}s; animation-delay: ${delay}s;`}
              />
            );
          })}
        </div>
      ))
  }

  {
    showCCW &&
      [
        { speedClass: "animate-[spin_70s_linear_infinite_reverse]" },
        { speedClass: "animate-[spin_110s_linear_infinite_reverse]" },
        { speedClass: "animate-[spin_150s_linear_infinite_reverse]" },
      ].map((layer) => (
        <div
          class={`absolute inset-0 w-full h-full origin-center ${layer.speedClass}`}
        >
          {Array.from({ length: Math.ceil(ccwCount / 3) }).map(() => {
            const r = 150 + Math.random() * 900;
            const angle = Math.random() * 360;
            const size = Math.random() * 4 + 1.5;
            const opacity = Math.random() * 0.3 + 0.1;
            return (
              <div
                class={`absolute rounded-full ${ccwColorClass}`}
                style={`top: calc(50% + ${Math.sin((angle * Math.PI) / 180) * r}px); left: calc(50% + ${Math.cos((angle * Math.PI) / 180) * r}px); width: ${size}px; height: ${size}px; opacity: ${opacity};`}
              />
            );
          })}
        </div>
      ))
  }
</div>
