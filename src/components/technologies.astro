---
import stacks from "../data/stacks.json";
import SectionHeader from "./section-header.astro";

const technologyGroups = [
  {
    heading: "Frontend",
    description: "Interactive UI and performant web experiences.",
    skills: [
      stacks.Next,
      stacks.React,
      stacks.Redux,
      stacks.Angular,
      stacks.RxJs,
      stacks.Electron,
      stacks.JS,
      stacks.TS,
      stacks.Html,
      stacks.CSS,
      stacks.Sass,
      stacks.AntDesign,
      stacks.AntV,
      stacks.MUI,
      stacks.Kendo,
      stacks.Shadcn,
      stacks.Tailwindcss,
      stacks.ReactQuery,
    ],
  },
  {
    heading: "Backend",
    description: "API architecture, integrations, and business logic.",
    skills: [
      stacks.Node,
      stacks.Express,
      stacks.Postman,
      stacks.Swagger,
      stacks.Mongoose,
    ],
  },
  {
    heading: "Databases",
    description: "Data modeling and persistence for scalable apps.",
    skills: [stacks.Sql, stacks.MongoDB, stacks.Firebase],
  },
  {
    heading: "Services",
    description: "Cloud and platform services used in delivery.",
    skills: [
      stacks.Clerk,
      stacks.JWT,
      stacks.Vercel,
      stacks.Render,
      stacks.Heroku,
      stacks.Pinecone,
      stacks.Cloudinary,
    ],
  },
  {
    heading: "Tools",
    description: "Developer tooling for quality, velocity, and collaboration.",
    skills: [
      stacks.Webpack,
      stacks.Git,
      stacks.GitHub,
      stacks.GitHubActions,
      stacks.Bitbucket,
      stacks.AzureDevOps,
      stacks.Figma,
      stacks.VSCode,
      stacks.ESlint,
      stacks.Prettier,
      stacks.SonarQube,
      stacks.NPM,
    ],
  },
  {
    heading: "AI Tools",
    description: "LLM-first tooling used to ship AI-powered products.",
    skills: [stacks.GPT, stacks.V0, stacks.GoogleAIStudio, stacks.LangChain],
  },
  {
    heading: "Project Workflow",
    description: "Planning, communication, and delivery methodologies.",
    skills: [
      stacks.Jira,
      stacks.Scrum,
      stacks.AzureBoards,
      stacks.GitHubBoards,
      stacks.Slack,
      stacks.Discord,
    ],
  },
  {
    heading: "Testing",
    description: "Confidence through repeatable testing and reviews.",
    skills: [stacks.Jest, stacks.Storybook, stacks.NUnit],
  },
];

const totalSkills = technologyGroups.reduce(
  (count, group) => count + group.skills.length,
  0,
);
---

<section id="technologies" class="max-w-6xl mx-auto px-7 lg:px-0">
  <SectionHeader
    heading="Technologies"
    subheading="These are the tools, frameworks, and technologies that I have worked with, each playing a key role in bringing ideas to life."
  />

  <div
    class="mb-6 rounded-2xl border border-neutral-200 bg-neutral-50/70 px-5 py-4 dark:border-neutral-800 dark:bg-neutral-900/60"
  >
    <p class="text-sm text-neutral-600 dark:text-neutral-300">
      Built with
      <span class="font-semibold">
        {totalSkills} production tools
      </span>
      across frontend engineering, backend systems, AI workflows, and delivery.
    </p>
  </div>

  <div class="grid w-full items-stretch gap-8 pb-7 sm:grid-cols-2">
    {
      technologyGroups.map((group) => (
        <article class="group relative rounded-2xl border border-neutral-200 bg-white p-5 transition duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-neutral-200/60 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:shadow-black/30">
          <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-neutral-300 to-transparent dark:via-neutral-700" />

          <div class="mb-3 flex items-center justify-between gap-3">
            <h3 class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
              {group.heading}
            </h3>
            <span class="rounded-full border border-neutral-300 bg-neutral-100 px-2.5 py-1 text-xs font-medium text-neutral-700 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300">
              {group.skills.length} tools
            </span>
          </div>

          <p class="text-sm text-neutral-600 dark:text-neutral-400">
            {group.description}
          </p>

          <ul class="mt-4 flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <li>
                <a
                  target="_blank"
                  rel="noreferrer"
                  href={skill.website}
                  title={skill.title}
                  class="inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-neutral-50 px-2.5 py-1.5 text-xs font-medium text-neutral-700 transition hover:border-neutral-300 hover:bg-white hover:text-neutral-900 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:border-neutral-500 dark:hover:bg-neutral-700 dark:hover:text-neutral-100"
                >
                  <img
                    class="size-3.5 rounded-sm object-cover"
                    src={`/assets/images/stack/${skill.name}.svg`}
                    alt={skill.title}
                    loading="lazy"
                  />
                  <span>{skill.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>
