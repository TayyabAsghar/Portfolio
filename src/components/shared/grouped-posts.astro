---
import { Picture } from "astro:assets";
import { formatDate, groupedPosts, sortedYears } from "../../utils";
import HoverPencilBackground from "../ui/hover-pencil-background.astro";
---

{
  sortedYears.map((year) => (
    <section class="flex flex-col md:flex-row gap-8 md:gap-16">
      <div class="md:w-32 flex-shrink-0">
        <h2 class="text-4xl font-extrabold text-neutral-300 dark:text-neutral-800 sticky top-24 tracking-tighter">
          {year}
        </h2>
      </div>

      <div class="flex-1 flex flex-col divide-y dividerline">
        {groupedPosts[year].map((post) => (
          <article class="relative cursor-pointer group py-4 first:pt-0 last:pb-0 grid grid-rows-1 grid-cols-1 sm:grid-cols-[3fr_1fr] gap-7 ">
            <HoverPencilBackground strokeWidth={5} animationDuration={1000} />

            <a href={`/blog/${post.slug}`} class="absolute inset-0 z-10">
              <span class="sr-only">Read {post.data.title}</span>
            </a>

            <div class="flex flex-col justify-center flex-1 pr-4">
              <div class="flex items-center gap-3 text-[0.55rem] font-bold tracking-[0.2em] text-neutral-500 dark:text-neutral-600 uppercase mb-3">
                <span>{formatDate(post.data.publishDate)}</span>

                {post.data.category && (
                  <>
                    <span class="w-[3px] h-[3px] rounded-full bg-neutral-300 dark:bg-neutral-700" />

                    <span class="text-neutral-900 dark:text-neutral-100 font-semibold tracking-[0.1em]">
                      {post.data.category}
                    </span>
                  </>
                )}
              </div>

              <h3 class="text-lg md:text-xl font-bold text-neutral-800 dark:text-neutral-200 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 leading-snug">
                {post.data.title}
              </h3>
            </div>

            {post.data.image && (
              <div class="flex w-full h-full ">
                <div class="relative w-full aspect-video rounded overflow-hidden opacity-80 dark:opacity-60 group-hover:opacity-100 transition-all duration-500">
                  <Picture
                    width={400}
                    height={225}
                    src={post.data.image}
                    alt={post.data.title}
                    formats={["avif", "webp", "jpg"]}
                    class="w-full h-full object-cover transform scale-95 group-hover:scale-100 transition-all duration-700 ease-out relative"
                  />
                </div>
              </div>
            )}
          </article>
        ))}
      </div>
    </section>
  ))
}
