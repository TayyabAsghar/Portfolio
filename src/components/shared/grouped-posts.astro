---
import { Picture } from "astro:assets";
import { formatDate, groupedPosts, sortedYears } from "../../utils";
---

{
  sortedYears.map((year) => (
    <section class="flex flex-col md:flex-row gap-8 md:gap-16">
      <div class="md:w-32 flex-shrink-0">
        <h2 class="text-4xl font-extrabold text-neutral-300 dark:text-neutral-800 sticky top-24 tracking-tighter">
          {year}
        </h2>
      </div>

      <div class="flex-1 flex flex-col">
        {groupedPosts[year].map((post, index) => {
          const isLast = index === groupedPosts[year].length - 1;
          return (
            <article
              class={`group relative flex justify-between items-center gap-8 py-8 ${!isLast ? "border-b border-neutral-200 dark:border-neutral-900 border-dashed" : ""} transition-opacity duration-300`}
            >
              <a
                href={`/blog/${post.slug}`}
                class="absolute inset-0 z-10"
              >
                <span class="sr-only">Read {post.data.title}</span>
              </a>

              <div class="flex flex-col justify-center flex-1 pr-4">
                <div class="flex items-center gap-3 text-[0.55rem] font-bold tracking-[0.2em] text-neutral-500 dark:text-neutral-600 uppercase mb-3">
                  <span>{formatDate(post.data.publishDate)}</span>
                  {post.data.category && (
                    <>
                      <span class="w-[3px] h-[3px] rounded-full bg-neutral-300 dark:bg-neutral-700" />
                      <span class="text-neutral-900 dark:text-neutral-100 font-semibold tracking-[0.1em]">
                        {post.data.category}
                      </span>
                    </>
                  )}
                </div>

                <h3 class="text-lg md:text-xl font-bold text-neutral-800 dark:text-neutral-200 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 leading-snug">
                  {post.data.title}
                </h3>
              </div>

              {post.data.image && (
                <div class="w-32 sm:w-40 flex-shrink-0 flex items-center justify-center">
                  <div class="relative w-full aspect-[16/9] rounded overflow-hidden shadow-sm dark:shadow-[0_0_15px_rgba(255,255,255,0.02)] border border-neutral-200 dark:border-white/5 opacity-80 dark:opacity-60 group-hover:opacity-100 group-hover:border-neutral-300 dark:group-hover:border-white/10 transition-all duration-500">
                    <Picture
                      src={post.data.image}
                      formats={["avif", "webp", "jpg"]}
                      alt={post.data.title}
                      width={400}
                      height={225}
                      class="w-full h-full object-cover transform scale-[1.02] group-hover:scale-105 transition-transform duration-700 ease-out"
                    />
                  </div>
                </div>
              )}
            </article>
          );
        })}
      </div>
    </section>
  ))
}
