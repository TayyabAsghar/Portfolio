---
import { Picture } from "astro:assets";

interface Props {
  alt: string;
  image: string;
  width: number;
  height: number;
  coverSize: string;
  styles?: string;
  gradient?: string;
  loading?: "eager" | "lazy";
  tiltDirection?: "left" | "right";
}

const {
  alt,
  image,
  width,
  height,
  styles,
  gradient,
  coverSize,
  loading = "lazy",
  tiltDirection = "right",
} = Astro.props;

const tiltStyles =
  tiltDirection === "right"
    ? "[transform:rotateX(8deg)_rotateY(-16deg)_rotateZ(3deg)]"
    : "[transform:rotateX(8deg)_rotateY(16deg)_rotateZ(-3deg)]";
---

<div class={`relative group ${coverSize} perspective-[2000px] p-10`}>
  {
    gradient && (
      <div
        class={`absolute inset-0 bg-linear-to-tr ${gradient} rounded-full blur-[100px] opacity-[0.03] group-hover:opacity-[0.08] transition-all duration-1000 ease-in-out`}
      />
    )
  }

  <div
    class:list={[
      "relative w-full h-full transition-all duration-700 ease-out transform-3d group-hover:transform-[rotateX(0deg)_rotateY(0deg)_rotateZ(0deg)_scale(1.02)]",
      tiltStyles,
    ]}
  >
    {
      gradient && (
        <>
          <div
            class={`absolute -inset-4 bg-linear-to-tr ${gradient} rounded-2xl opacity-[0.02] blur-sm transform [translateZ(-30px)] transition-all duration-700 group-hover:opacity-[0.06] group-hover:-inset-5`}
          />
          <div
            class={`absolute -inset-2 bg-linear-to-br ${gradient} rounded-xl opacity-[0.04] blur-[1px] transform [translateZ(-15px)] transition-all duration-700 group-hover:opacity-[0.1] group-hover:-inset-2.5`}
          />
        </>
      )
    }

    <div
      class="relative p-[1.5px] rounded-xl bg-linear-to-br from-white/30 via-white/5 to-transparent border border-white/10 shadow-none dark:shadow-[0_40px_80px_rgba(0,0,0,0.4)] overflow-hidden backdrop-blur-sm"
    >
      <div class="bg-neutral-900 rounded-[0.65rem] overflow-hidden">
        <div
          class="flex items-center gap-1.5 px-4 py-2.5 border-b border-white/5 bg-white/3"
        >
          <div
            class="w-2 h-2 rounded-full bg-[#FF5F56] dark:shadow-[0_0_10px_rgba(255,95,86,0.3)]"
          >
          </div>
          <div
            class="w-2 h-2 rounded-full bg-[#FFBD2E] dark:shadow-[0_0_10px_rgba(255,189,46,0.3)]"
          >
          </div>
          <div
            class="w-2 h-2 rounded-full bg-[#27C93F] dark:shadow-[0_0_10px_rgba(39,201,63,0.3)]"
          >
          </div>
        </div>

        <div
          class="relative overflow-hidden group-hover:brightness-110 transition-all duration-700"
        >
          <Picture
            alt={alt}
            src={image}
            width={width}
            height={height}
            loading={loading}
            formats={["avif", "webp", "jpg"]}
            class={`w-full aspect-video object-cover transform transition-transform duration-1000 ease-out group-hover:scale-[1.04] ${styles || ""}`}
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent pointer-events-none opacity-60 group-hover:opacity-20 transition-opacity duration-700"
          >
          </div>
        </div>
      </div>
    </div>

    <div
      class="absolute inset-4 bg-transparent dark:bg-black/40 rounded-xl blur-2xl transform-[translateZ(-50px)] -z-10 opacity-0 group-hover:opacity-100 transition-all duration-700"
    >
    </div>
  </div>
</div>
