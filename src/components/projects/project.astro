---
import { ImageTile } from "../shared";

interface Props {
  name: string;
  slug: string;
  company: string;
  hrefBase: string;
  gradient: string;
  description: string;
  index?: number;
  image?: string;
  layout?: "card" | "list";
}

const {
  name,
  slug,
  image,
  index,
  company,
  gradient,
  hrefBase,
  description,
  layout = "card",
} = Astro.props;

const baseStyle = "w-full h-full rounded-xl";

const layoutStyle: any = {
  card: "flex flex-col gap-6",
  list: `flex flex-col-reverse gap-8 justify-between md:gap-52 ${index !== undefined && index % 2 !== 0 ? "md:flex-row" : "md:flex-row-reverse"}`,
};

const coverSize: any = {
  card: "w-full",
  list: "w-full md:w-[45%]",
};

const headingStyle: any = {
  card: "text-base line-clamp-2",
  list: "text-lg",
};

const descriptionClamp: any = {
  card: "line-clamp-5 md:line-clamp-3",
  list: "line-clamp-4 md:line-clamp-3",
};

const visibility: any = {
  card: "!hidden",
  list: "",
};

const transitionStyle = "transition-all duration-700 ease-out";

const textHoverStyle =
  "group-hover:text-neutral-900 dark:group-hover:text-neutral-100";
---

<a
  data-layout={layout}
  href={`${hrefBase}/${slug}`}
  class="relative flex flex-col w-full items-stretch group rounded-xl"
  class:list={[transitionStyle]}
>
  <div
    class:list={[baseStyle, layoutStyle[layout]]}
    data-project-row={layout === "list" ? "true" : undefined}
    data-direction={layout === "list"
      ? index !== undefined && index % 2 !== 0
        ? "row"
        : "row-reverse"
      : undefined}
  >
    {
      image && (
        <div data-project-image class={coverSize[layout]}>
          <ImageTile
            alt={name}
            width={800}
            height={450}
            image={image}
            gradient={gradient}
            coverSize="w-full"
            tiltDirection={
              layout === "list"
                ? index !== undefined && index % 2 !== 0
                  ? "right"
                  : "left"
                : "right"
            }
          />
        </div>
      )
    }

    <div
      data-project-text
      class="flex flex-col w-full justify-center divide-y-4 divide-transparent flex-1"
    >
      <div
        class="flex relative gap-2 items-start justify-start mb-0 font-semibold tracking-tight text-neutral-800 hover:text-black dark:text-neutral-100 dark:hover:text-white"
        class:list={[headingStyle[layout]]}
      >
        <div
          class="text-lg md:text-xl font-bold text-neutral-800 dark:text-neutral-200 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 leading-snug"
          title={name}
        >
          {name}
        </div>
      </div>

      <div
        class="text-base text-neutral-900 font-medium dark:text-neutral-400"
        class:list={[visibility[layout]]}
      >
        {company}
      </div>

      <div
        class="text-sm text-neutral-600 dark:text-neutral-400"
        class:list={[
          descriptionClamp[layout],
          visibility[layout],
          textHoverStyle,
        ]}
      >
        {description}
      </div>
    </div>
  </div>
</a>
