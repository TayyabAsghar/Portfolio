---
import { ImageTile } from "../shared";

interface Props {
  slug: string;
  title: string;
  index: number;
  image: string;
  tags: string[];
  hrefBase: string;
  gradient: string;
  description: string;
}

const { tags, slug, title, image, index, hrefBase, gradient, description } =
  Astro.props;
---

<div
  class={`flex flex-col md:flex-row items-center gap-10 md:gap-20 mb-32 last:mb-0 ${index % 2 ? "" : "md:flex-row-reverse"}`}
>
  <div data-project-image class="w-full md:w-[45%]">
    <a href={`${hrefBase}/${slug}`}>
      <ImageTile
        alt={title}
        width={800}
        height={450}
        image={image}
        gradient={gradient}
        coverSize="w-full"
        tiltDirection={index % 2 ? "right" : "left"}
      />
    </a>
  </div>

  <div class="w-full md:w-1/2 flex flex-col items-start px-2">
    <h3
      class="text-xl sm:text-2xl font-bold text-neutral-900 dark:text-white mb-6 leading-tight tracking-tight"
    >
      {title}
    </h3>

    <p
      class="text-neutral-600 dark:text-neutral-400 mb-8 leading-relaxed max-w-xl"
    >
      {description}
    </p>

    <div class="flex flex-wrap gap-3">
      {
        tags.map((tag) => (
          <span class="px-4 py-1.5 rounded-full border bg-neutral-500/5 dark:bg-white/10 border-neutral-200 dark:border-neutral-800 text-xs md:text-sm text-neutral-600 dark:text-neutral-200 font-semibold hover:border-neutral-400 dark:hover:border-neutral-600 hover:bg-neutral-100 dark:hover:bg-white/20 transition-all cursor-default">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</div>
