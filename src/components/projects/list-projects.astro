---
import { Separator } from "../ui";
import Project from "./project.astro";
import { latestPortfolio } from "../../utils/portfolio";

interface Props {
  link?: string;
  count?: number;
  offset?: number;
  company?: string;
  className?: string;
  brandLogo?: string;
  flipDuration?: number;
  flipInterval?: number;
}

const {
  link,
  count,
  company,
  brandLogo,
  offset = 0,
  className = "",
  flipDuration = 1000,
  flipInterval = 8000,
} = Astro.props;

let portfolio;
portfolio = company
  ? latestPortfolio.filter((project) => project.data.company === company)
  : latestPortfolio;

portfolio = count ? portfolio.slice(0, count) : portfolio;

const collection = portfolio;
---

{!!company && <Separator link={link} text={company} brandLogo={brandLogo} />}

<div
  class="flex flex-col gap-10"
  class:list={[className, !company ? "mt-20" : ""]}
>
  {
    collection.map((project, index) => {
      const globalIndex = index + offset;

      return (
        <div
          class="relative py-4 first:pt-0 after:absolute after:left-1/2 after:-bottom-5 after:h-px after:w-full after:-translate-x-1/2 after:bg-neutral-100 last:after:hidden dark:after:bg-neutral-800"
          data-flip-duration={flipDuration}
          data-flip-interval={flipInterval}
        >
          <Project
            layout="list"
            slug={project.id}
            index={globalIndex}
            hrefBase="portfolio"
            name={project.data.title}
            image={project.data.image}
            company={project.data.company}
            gradient={project.data.bgGradient}
            description={project.data.description}
          />
        </div>
      );
    })
  }
</div>

<script src="../../assets/js/project-flip.js"></script>
