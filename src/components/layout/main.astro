---
import "../../assets/css/main.css";
import { about } from "../../data";
import Footer from "./footer.astro";
import Header from "./header.astro";
import { SquareLines } from "../backgrounds";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  image?: string;
  noIndex?: boolean;
  description?: string;
  type?: "article" | "website";
}

const {
  title,
  image,
  noIndex = false,
  type = "website",
  description = about.landingIntro,
} = Astro.props;

const siteName = about.name;
const siteUrl = Astro.site ?? import.meta.env.PUBLIC_SITE_URL;
const absoluteUrl = (path?: string) => {
  if (!path || !siteUrl) return undefined;

  return new URL(path, siteUrl).toString();
};
const canonicalUrl = absoluteUrl(Astro.url.pathname);
const socialImage = absoluteUrl(image ?? "/assets/images/about.avif");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="p:domain_verify" content="70c58a6597b091ed1aa21054f3800753" />
    <meta name="description" content={description} />
    <meta name="author" content={siteName} />
    <meta
      name="robots"
      content={noIndex ? "noindex, nofollow" : "index, follow"}
    />
    <meta
      name="theme-color"
      content="#0a0a0a"
      media="(prefers-color-scheme: dark)"
    />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <meta name="color-scheme" content="light dark" />

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {socialImage && <meta property="og:image" content={socialImage} />}

    <meta
      name="twitter:card"
      content={socialImage ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}

    <title>{title}</title>
    <ClientRouter />

    <!-- Used to add dark mode right away, adding here prevents any flicker -->
    <script is:inline data-astro-rerun>
      if (typeof Storage !== "undefined") {
        const isDarkMode =
          localStorage.getItem("dark_mode") &&
          localStorage.getItem("dark_mode") == "true";

        if (isDarkMode) document.documentElement.classList.add("dark");
      }
    </script>

    <!-- Google tag (gtag.js) -->
    <script
      async
      is:inline
      src="https://www.googletagmanager.com/gtag/js?id=G-FE1RECDFFZ"></script>

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }

      gtag("js", new Date());

      gtag("config", "G-FE1RECDFFZ");
    </script>

    <link rel="icon" type="image/x-icon" href="../../assets/images/logo.svg" />

    <Fragment set:html={import.meta.env.HEADER_INJECT} />
  </head>

  <body
    class="relative min-h-screen flex flex-col antialiased overflow-x-hidden bg-white dark:bg-neutral-950"
  >
    <SquareLines />

    <Header />

    <div class="relative flex-1 flex flex-col">
      <main>
        <slot />
      </main>

      <SquareLines bottom />
    </div>

    <Footer />

    <script src="../../assets/js/main.js"></script>

    <Fragment set:html={import.meta.env.FOOTER_INJECT} />
  </body>
</html>
