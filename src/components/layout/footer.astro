---
import Logo from "../ui/logo.astro";
import socials from "../../data/socials.json";

const currentYear = new Date().getFullYear();
---

<section
  class="text-gray-700 bg-white border-t sm:mt-20 dark:bg-neutral-950 border-neutral-200 dark:border-neutral-800"
>
  <div
    class="container flex flex-col items-center py-8 mx-auto px-7 max-w-8xl sm:flex-row"
  >
    <Logo />
    <p
      class="mt-4 text-xsm tracking-most-widest text-neutral-500 dark:text-neutral-500 sm:ml-4 sm:pl-4 sm:border-l border-neutral-300 dark:border-neutral-700 sm:mt-0"
    >
      &copy; {currentYear} Tayyab Asghar. All rights are reserved.
    </p>

    <div
      class="flex flex-col sm:flex-row items-center justify-center mt-8 sm:mt-0 gap-6 sm:ml-auto"
    >
      <div
        class="flex items-center gap-6 text-xsm font-bold tracking-most-widest uppercase"
      >
        {
          socials.map((social) => (
            <a
              href={social.url}
              target={social.target}
              class="text-neutral-500 dark:text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors"
            >
              {social.name}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
