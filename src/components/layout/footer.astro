---
import { Logo } from "../ui";
import { about, socials } from "../../data";

const currentYear = new Date().getFullYear();
---

<section
  class="text-gray-700 -scale-z-100 bg-white border-t dark:bg-neutral-950 border-neutral-200 dark:border-neutral-800"
>
  <div
    class="container flex flex-col items-center py-5 mx-auto px-7 max-w-8xl sm:flex-row"
  >
    <div class="flex items-center w-full sm:w-auto">
      <Logo />
      <p
        class="text-[9px] min-[380px]:text-xsm sm:text-msm tracking-widest text-neutral-500 dark:text-neutral-500 ml-3 pl-3 sm:ml-4 sm:pl-4 border-l border-neutral-300 dark:border-neutral-700 whitespace-nowrap"
      >
        &copy; {currentYear}
        {about.name}. All rights are reserved.
      </p>
    </div>

    <div
      class="flex flex-col sm:flex-row items-center justify-center mt-8 sm:mt-0 gap-6 sm:ml-auto"
    >
      <div
        class="flex items-center gap-6 text-xsm font-bold tracking-most-widest uppercase"
      >
        {
          socials.map((social) => (
            <a
              href={social.url}
              target={social.target}
              rel={social.target === "_blank" ? "noopener noreferrer" : undefined}
              class="text-neutral-500 dark:text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors"
            >
              {social.name}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
