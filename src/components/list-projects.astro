---
import Project from "../components/project.astro";
import { latestPortfolio } from "../utils/portfolio";
import Separator from "../components/separator.astro";

interface Props {
  link?: string;
  count?: number;
  className?: string;
  company?: string;
  brandLogo?: string;
}

const { count, company, link, brandLogo, className = "" } = Astro.props;

let portfolio;
portfolio = company
  ? latestPortfolio.filter((project) => project.data.company === company)
  : latestPortfolio;

portfolio = count ? portfolio.slice(0, count) : portfolio;

const collection = portfolio;
---

{!!company && <Separator link={link} text={company} brandLogo={brandLogo} />}

<div
  class="flex flex-col gap-10"
  class:list={[className, !company ? "mt-20" : ""]}
>
  {
    collection.map((project) => (
      <div class="relative py-4 first:pt-0 after:absolute after:left-1/2 after:-bottom-5 after:h-px after:w-full after:-translate-x-1/2 after:bg-neutral-100 last:after:hidden dark:after:bg-neutral-800">
        <Project
          layout="list"
          slug={project.slug}
          hrefBase="portfolio"
          name={project.data.title}
          image={project.data.image}
          company={project.data.company}
          gradient={project.data.bgGradient}
          description={project.data.description}
        />
      </div>
    ))
  }
</div>
