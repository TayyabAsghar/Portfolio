---
interface Props {
  name: string;
  logo: string;
  media: string;
  index: number;
  length: number;
  issueDate: string;
  organization: string;
  credentialURL: string;
  credentialID?: string;
  expirationDate?: string;
  viewType?: "marquee" | "grid";
}

const {
  name,
  logo,
  media,
  index,
  length,
  issueDate,
  organization,
  credentialID,
  credentialURL,
  expirationDate,
  viewType = "marquee",
} = Astro.props;
---

<a
  target="_blank"
  rel="noreferrer"
  href={credentialURL}
  aria-label={`Open certificate ${name}`}
  aria-hidden={index >= length ? "true" : undefined}
  tabindex={index >= length ? -1 : undefined}
  class:list={[
    "group flex w-[290px] shrink-0 flex-col rounded-[1.75rem] border border-neutral-200 bg-white p-6 no-underline shadow-sm transition dark:border-neutral-800 dark:bg-neutral-950",
    viewType === "grid" ? "h-[380px]" : "h-[360px]",
  ]}
>
  <div class="mb-10 flex items-start justify-between gap-4">
    <img
      src={logo}
      alt={organization}
      class="m-0 h-10 w-10 rounded-xl object-cover"
    />

    <p
      class="m-0 text-[11px] font-semibold uppercase tracking-[0.18em] text-neutral-400 dark:text-neutral-500"
    >
      {credentialID ? `ID: ${credentialID}` : organization}
    </p>
  </div>

  <h3
    class="m-0 min-h-[64px] text-2xl font-bold leading-tight tracking-tight text-neutral-900 dark:text-neutral-100"
  >
    {name}
  </h3>

  <div class="mt-auto border-t border-neutral-200 pt-5 dark:border-neutral-800">
    <p
      class="m-0 text-sm font-semibold uppercase tracking-[0.18em] text-neutral-500 dark:text-neutral-400"
    >
      {organization}
    </p>

    <p
      class="mt-2 m-0 text-sm leading-6 text-neutral-500 dark:text-neutral-400"
    >
      Issued {issueDate}
      {expirationDate ? ` · ${expirationDate}` : ""}
    </p>
  </div>
</a>
