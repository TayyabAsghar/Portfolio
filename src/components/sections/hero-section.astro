---
import { about, music } from "../../data";
import { Projects, MusicPlayer, LinkButton, Typewriter } from "../ui";
---

<section class="px-7 lg:px-0 relative">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
    <div class="space-y-8">
      <h1
        class="text-4xl md:text-5xl lg:text-7xl font-black tracking-tighter text-neutral-900 dark:text-white"
      >
        <span
          class="block mb-2 opacity-50 text-xl md:text-2xl font-medium tracking-normal"
          >Hello, I'm</span
        >
        <Typewriter
          loop
          loopDelay={10000}
          text={about.name}
          class="bg-clip-text text-transparent bg-gradient-to-r leading-tight from-neutral-900 via-neutral-600 to-neutral-900 dark:from-white dark:via-neutral-400 dark:to-white"
        />
      </h1>

      <div class="space-y-6">
        <h2
          class="text-lg md:text-xl font-semibold text-neutral-800 dark:text-neutral-200 tracking-tight"
        >
          {about.heading}
        </h2>

        <p
          class="text-base md:text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed"
        >
          {about.landingIntro}
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-4 pt-4">
        <LinkButton
          target="_blank"
          text="Let's Connect"
          link={`mailto:${about.email}`}
        />

        <LinkButton
          text="Resume"
          target="_blank"
          variant="secondary"
          iconRight="open-in-new"
          link="/Muhammad_Tayyab_Asghar.pdf"
        />
      </div>
    </div>

    <div
      class="relative hidden md:block scale-[70%] lg:scale-[80%] origin-right -mt-12"
    >
      <Projects />

      <MusicPlayer tracks={music} />
    </div>
  </div>
</section>
