---
import Button from "../ui/button.astro";
import about from "../../data/about.json";
---

<section
  class="mt-16 rounded-[2rem] border border-neutral-200 bg-neutral-50/60 p-6 dark:border-neutral-800 dark:bg-neutral-900/50 md:p-8"
>
  <div
    class="grid gap-8 md:grid-cols-[minmax(0,1fr)_minmax(320px,520px)] md:gap-10"
  >
    <div class="max-w-xl">
      <p
        class="text-xs font-semibold uppercase tracking-[0.28em] text-neutral-500 dark:text-neutral-400"
      >
        Let's Connect
      </p>
      <h2
        class="mt-3 text-2xl font-bold leading-tight tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-3xl lg:text-4xl"
      >
        Let's build something exceptional.
      </h2>
      <p
        class="mt-6 text-sm leading-8 text-neutral-600 dark:text-neutral-400 sm:text-base lg:text-lg"
      >
        Currently open to high-impact product work, engineering roles, and
        thoughtful collaborations. Reach out and let’s start the conversation.
      </p>

      <div class="mt-10 space-y-5">
        <div class="flex items-start gap-4">
          <div
            class="flex h-12 w-12 items-center justify-center rounded-full border border-neutral-200 bg-white text-neutral-700 dark:border-neutral-800 dark:bg-neutral-950 dark:text-neutral-300"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path
                d="M4 7.5 12 13l8-5.5"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <rect
                x="3"
                y="5"
                width="18"
                height="14"
                rx="2.5"
                stroke="currentColor"
                stroke-width="1.8"></rect>
            </svg>
          </div>
          <div>
            <p
              class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500 dark:text-neutral-400"
            >
              Email
            </p>
            <a
              href={`mailto:${about.email}`}
              class="mt-1 block max-w-full break-all text-base font-medium text-neutral-900 transition hover:text-neutral-600 dark:text-neutral-100 dark:hover:text-neutral-300 sm:text-lg"
            >
              {about.email}
            </a>
          </div>
        </div>
      </div>
    </div>

    <form
      id="contact-form"
      data-email={about.email}
      class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-950"
    >
      <div class="space-y-5">
        <label class="block">
          <span
            class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500 dark:text-neutral-400"
          >
            Full Name
          </span>
          <input
            type="text"
            name="name"
            placeholder="John Doe"
            class="w-full rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-4 text-base text-neutral-900 outline-none transition placeholder:text-neutral-400 focus:border-neutral-300 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100 dark:placeholder:text-neutral-500 dark:focus:border-neutral-700"
          />
        </label>

        <label class="block">
          <span
            class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500 dark:text-neutral-400"
          >
            Email Address
          </span>
          <input
            type="email"
            name="email"
            placeholder="john@example.com"
            class="w-full rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-4 text-base text-neutral-900 outline-none transition placeholder:text-neutral-400 focus:border-neutral-300 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100 dark:placeholder:text-neutral-500 dark:focus:border-neutral-700"
          />
        </label>

        <label class="block">
          <span
            class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500 dark:text-neutral-400"
          >
            Message
          </span>
          <textarea
            name="message"
            rows="6"
            placeholder="How can I help you?"
            class="w-full rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-4 text-base text-neutral-900 outline-none transition placeholder:text-neutral-400 focus:border-neutral-300 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-100 dark:placeholder:text-neutral-500 dark:focus:border-neutral-700"
          ></textarea>
        </label>
      </div>

      <Button
        type="submit"
        text="Send Inquiry"
        id="contact-submit-btn"
        class="mt-6 px-6 py-4 disabled:cursor-not-allowed disabled:opacity-50"
        disabled
      />
    </form>
  </div>
</section>

<script src="../../assets/js/contact-form.js"></script>
