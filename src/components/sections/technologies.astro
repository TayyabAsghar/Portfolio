---
import TechHub from "./tech-hub.astro";
import stacks from "../../data/stacks.json";
import SolarRings from "./solar-rings.astro";
import CodeIcon from "../../icons/code.svg?raw";
import BrainIcon from "../../icons/brain.svg?raw";
import CloudIcon from "../../icons/cloud.svg?raw";
import ServerIcon from "../../icons/server.svg?raw";
import SectionHeader from "../ui/section-header.astro";
import DatabaseIcon from "../../icons/database.svg?raw";
import ServicesIcon from "../../icons/services.svg?raw";
import WorkflowIcon from "../../icons/workflow.svg?raw";
import TestingIcon from "../../icons/check-list.svg?raw";
import ParticleBackground from "../backgrounds/particle-background.astro";

const GROUPS = [
  {
    id: "frontend",
    color: "#6366f1",
    heading: "Frontend",
    icon: CodeIcon,
    skills: [
      stacks.Next,
      stacks.React,
      stacks.Redux,
      stacks.Angular,
      stacks.RxJs,
      stacks.Electron,
      stacks.JS,
      stacks.TS,
      stacks.Html,
      stacks.CSS,
      stacks.Sass,
      stacks.AntDesign,
      stacks.MUI,
      stacks.Shadcn,
      stacks.Tailwindcss,
      stacks.ReactQuery,
    ],
  },
  {
    id: "backend",
    color: "#10b981",
    heading: "Backend",
    icon: ServerIcon,
    skills: [
      stacks.Node,
      stacks.Express,
      stacks.Postman,
      stacks.Swagger,
      stacks.Mongoose,
    ],
  },
  {
    id: "databases",
    color: "#f59e0b",
    heading: "Databases",
    icon: DatabaseIcon,
    skills: [stacks.Sql, stacks.MongoDB, stacks.Firebase],
  },
  {
    id: "services",
    color: "#3b82f6",
    heading: "Services",
    icon: CloudIcon,
    skills: [
      stacks.Clerk,
      stacks.JWT,
      stacks.Vercel,
      stacks.Render,
      stacks.Heroku,
      stacks.Pinecone,
      stacks.Cloudinary,
    ],
  },
  {
    id: "tools",
    color: "#8b5cf6",
    heading: "Tools",
    icon: ServicesIcon,
    skills: [
      stacks.Webpack,
      stacks.Git,
      stacks.GitHub,
      stacks.GitHubActions,
      stacks.Bitbucket,
      stacks.AzureDevOps,
      stacks.Figma,
      stacks.VSCode,
      stacks.ESlint,
      stacks.Prettier,
      stacks.NPM,
    ],
  },
  {
    id: "ai",
    color: "#ec4899",
    heading: "AI Tools",
    icon: BrainIcon,
    skills: [stacks.GPT, stacks.V0, stacks.GoogleAIStudio, stacks.LangChain],
  },
  {
    id: "workflow",
    color: "#14b8a6",
    heading: "Workflow",
    icon: WorkflowIcon,
    skills: [
      stacks.Jira,
      stacks.Scrum,
      stacks.AzureBoards,
      stacks.GitHubBoards,
      stacks.Slack,
      stacks.Discord,
    ],
  },
  {
    id: "testing",
    color: "#f97316",
    heading: "Testing",
    icon: TestingIcon,
    skills: [stacks.Jest, stacks.Storybook, stacks.NUnit],
  },
];

const groupsJson = JSON.stringify(GROUPS);
---

<section
  id="technologies"
  class="relative px-7 lg:px-0 flex flex-col overflow-hidden py-10 w-full min-h-[600px]"
>
  <div class="hidden" aria-hidden="true">
    {
      GROUPS.flatMap((g) => g.skills).map((skill) => (
        <img
          loading="eager"
          alt={skill.name}
          src={`/assets/images/stack/${skill.name}.svg`}
        />
      ))
    }
  </div>

  <ParticleBackground density={10} direction="both" />

  <div class="relative z-10 w-full flex flex-col">
    <SectionHeader
      heading="Technologies"
      subheading="A digital ecosystem orbiting a single core. Click any group to explore its stack."
    />

    <div class="os-root overflow-visible pointer-events-none">
      <div
        class="relative w-full max-w-[700px] aspect-square flex items-center justify-center pointer-events-none [perspective:3000px] [transform-style:preserve-3d]"
      >
        <ul
          class="os-wrap pointer-events-none [transform-style:preserve-3d] [transform:translateZ(100px)]"
          id="os-wrap"
          data-groups={groupsJson}
        >
          <TechHub />

          <SolarRings
            scaleX={350}
            scaleY={140}
            trailWidth={4}
            groups={GROUPS}
            itemsPerRing={1}
            trailFactor={0.8}
          />
        </ul>
      </div>
    </div>
  </div>
</section>

<script src="../../assets/js/technologies.js"></script>
