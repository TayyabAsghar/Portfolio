---
import TechHub from "./tech-hub.astro";
import stacks from "../../data/stacks.json";
import SectionHeader from "../ui/section-header.astro";

const GROUPS = [
  {
    id: "frontend",
    heading: "Frontend",
    color: "#6366f1",
    description: "Interactive UI and performant web experiences.",
    icon: `<path d="M16 18l6-6-6-6M8 6l-6 6 6 6" />`,
    skills: [
      stacks.Next,
      stacks.React,
      stacks.Redux,
      stacks.Angular,
      stacks.RxJs,
      stacks.Electron,
      stacks.JS,
      stacks.TS,
      stacks.Html,
      stacks.CSS,
      stacks.Sass,
      stacks.AntDesign,
      stacks.MUI,
      stacks.Shadcn,
      stacks.Tailwindcss,
      stacks.ReactQuery,
    ],
  },
  {
    id: "backend",
    heading: "Backend",
    color: "#10b981",
    description: "API architecture, integrations, and business logic.",
    icon: `<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`,
    skills: [
      stacks.Node,
      stacks.Express,
      stacks.Postman,
      stacks.Swagger,
      stacks.Mongoose,
    ],
  },
  {
    id: "databases",
    heading: "Databases",
    color: "#f59e0b",
    description: "Data modeling and persistence for scalable apps.",
    icon: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>`,
    skills: [stacks.Sql, stacks.MongoDB, stacks.Firebase],
  },
  {
    id: "services",
    heading: "Services",
    color: "#3b82f6",
    description: "Cloud and platform services used in delivery.",
    icon: `<path d="M17.5 19c2.5 0 4.5-2 4.5-4.5 0-2.3-1.7-4.2-3.9-4.5C17.6 7.2 15.1 5 12 5c-2.6 0-4.8 1.6-5.7 3.9C4.1 9.2 2 11.4 2 14.5 2 17 4 19 6.5 19z"/>`,
    skills: [
      stacks.Clerk,
      stacks.JWT,
      stacks.Vercel,
      stacks.Render,
      stacks.Heroku,
      stacks.Pinecone,
      stacks.Cloudinary,
    ],
  },
  {
    id: "tools",
    heading: "Tools",
    color: "#8b5cf6",
    description: "Developer tooling for quality and collaboration.",
    icon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
    skills: [
      stacks.Webpack,
      stacks.Git,
      stacks.GitHub,
      stacks.GitHubActions,
      stacks.Bitbucket,
      stacks.AzureDevOps,
      stacks.Figma,
      stacks.VSCode,
      stacks.ESlint,
      stacks.Prettier,
      stacks.NPM,
    ],
  },
  {
    id: "ai",
    heading: "AI Tools",
    color: "#ec4899",
    description: "LLM-first tooling to ship AI-powered products.",
    icon: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`,
    skills: [stacks.GPT, stacks.V0, stacks.GoogleAIStudio, stacks.LangChain],
  },
  {
    id: "workflow",
    heading: "Workflow",
    color: "#14b8a6",
    description: "Planning, communication, and delivery methods.",
    icon: `<rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M9 14l2 2 4-4"/>`,
    skills: [
      stacks.Jira,
      stacks.Scrum,
      stacks.AzureBoards,
      stacks.GitHubBoards,
      stacks.Slack,
      stacks.Discord,
    ],
  },
  {
    id: "testing",
    heading: "Testing",
    color: "#f97316",
    description: "Confidence through repeatable testing and reviews.",
    icon: `<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>`,
    skills: [stacks.Jest, stacks.Storybook, stacks.NUnit],
  },
];

function getEllipsePathStr(rx: number, ry: number) {
  return `M -${rx} 0 A ${rx} ${ry} 0 1 1 ${rx} 0 A ${rx} ${ry} 0 1 1 -${rx} 0`;
}

const SCALE_X = 350;
const SCALE_Y = 80;
const ITEMS_PER_RING = 1;

const SOLAR_RINGS = [];
for (let i = 0; i < GROUPS.length; i += ITEMS_PER_RING) {
  const ringGroups = GROUPS.slice(i, i + ITEMS_PER_RING);
  const ringIdx = Math.floor(i / ITEMS_PER_RING);
  const totalRings = Math.ceil(GROUPS.length / ITEMS_PER_RING);
  const rotZ = ringIdx * (180 / totalRings);
  const rotX = 55 + (ringIdx % 2 === 0 ? 15 : 0);
  const spd = 24 + ringIdx * 3;

  SOLAR_RINGS.push({
    rx: SCALE_X,
    ry: SCALE_Y,
    spd,
    rotX,
    rotZ,
    groups: ringGroups,
  });
}

const groupsJson = JSON.stringify(GROUPS);
---

<section id="technologies" class="max-w-7xl mx-auto px-7 lg:px-0">
  <SectionHeader
    heading="Technologies"
    subheading="A digital ecosystem orbiting a single core. Click any group to explore its stack."
  />

  <div class="os-root overflow-visible h-[650px] pointer-events-none">
    <div
      class="relative w-[700px] h-[700px] flex items-center justify-center pointer-events-none [perspective:2000px] [transform-style:preserve-3d]"
    >
      <ul
        class="os-wrap !w-full !h-full pointer-events-none [transform-style:preserve-3d] [transform:translateZ(100px)]"
        id="os-wrap"
        data-groups={groupsJson}
      >
        <TechHub />

        {
          SOLAR_RINGS.map((ring, ridx) => {
            const pathStr = getEllipsePathStr(ring.rx, ring.ry);

            return (
              <li
                class="sol-ring-li w-0 h-0 [transform-style:preserve-3d] pointer-events-none"
                style={`transform: rotateZ(${ring.rotZ}deg) rotateX(${ring.rotX}deg);`}
              >
                <div
                  class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 border border-dashed border-neutral-800/30 dark:border-white/10 rounded-[50%] pointer-events-none"
                  style={`width:${ring.rx * 2}px; height:${ring.ry * 2}px;`}
                />

                {ring.groups.map((g, gi) => {
                  const delay =
                    -(gi / ring.groups.length) * ring.spd -
                    Math.random() * ring.spd;
                  return (
                    <div
                      class="os-item pointer-events-auto w-0 h-0 [transform-style:preserve-3d]"
                      style={`offset-path: path('${pathStr}'); animation-duration: ${ring.spd}s; animation-delay: ${delay}s;`}
                    >
                      <div
                        class="[transform-style:preserve-3d]"
                        style={`transform: translate(-50%, -50%) rotateX(-${ring.rotX}deg) rotateZ(-${ring.rotZ}deg);`}
                      >
                        <button
                          class="os-gplanet"
                          data-gid={g.id}
                          style={`--pc:${g.color};`}
                        >
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="gp-icon"
                            set:html={g.icon}
                          />
                          <span class="gp-count">{g.skills.length}</span>
                          <span class="gp-tip">{g.heading}</span>
                        </button>
                      </div>
                    </div>
                  );
                })}
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</section>

<script src="../../assets/js/technologies.js"></script>
