---
import TechHub from "./tech-hub.astro";
import stacks from "../../data/stacks.json";
import CodeIcon from "../../icons/code.svg?raw";
import BrainIcon from "../../icons/brain.svg?raw";
import CloudIcon from "../../icons/cloud.svg?raw";
import ServerIcon from "../../icons/server.svg?raw";
import SectionHeader from "../ui/section-header.astro";
import DatabaseIcon from "../../icons/database.svg?raw";
import ServicesIcon from "../../icons/services.svg?raw";
import WorkflowIcon from "../../icons/workflow.svg?raw";
import TestingIcon from "../../icons/check-list.svg?raw";

const GROUPS = [
  {
    id: "frontend",
    color: "#6366f1",
    heading: "Frontend",
    description: "Interactive UI and performant web experiences.",
    icon: CodeIcon,
    skills: [
      stacks.Next,
      stacks.React,
      stacks.Redux,
      stacks.Angular,
      stacks.RxJs,
      stacks.Electron,
      stacks.JS,
      stacks.TS,
      stacks.Html,
      stacks.CSS,
      stacks.Sass,
      stacks.AntDesign,
      stacks.MUI,
      stacks.Shadcn,
      stacks.Tailwindcss,
      stacks.ReactQuery,
    ],
  },
  {
    id: "backend",
    color: "#10b981",
    heading: "Backend",
    description: "API architecture, integrations, and business logic.",
    icon: ServerIcon,
    skills: [
      stacks.Node,
      stacks.Express,
      stacks.Postman,
      stacks.Swagger,
      stacks.Mongoose,
    ],
  },
  {
    id: "databases",
    color: "#f59e0b",
    heading: "Databases",
    description: "Data modeling and persistence for scalable apps.",
    icon: DatabaseIcon,
    skills: [stacks.Sql, stacks.MongoDB, stacks.Firebase],
  },
  {
    id: "services",
    color: "#3b82f6",
    heading: "Services",
    description: "Cloud and platform services used in delivery.",
    icon: CloudIcon,
    skills: [
      stacks.Clerk,
      stacks.JWT,
      stacks.Vercel,
      stacks.Render,
      stacks.Heroku,
      stacks.Pinecone,
      stacks.Cloudinary,
    ],
  },
  {
    id: "tools",
    color: "#8b5cf6",
    heading: "Tools",
    description: "Developer tooling for quality and collaboration.",
    icon: ServicesIcon,
    skills: [
      stacks.Webpack,
      stacks.Git,
      stacks.GitHub,
      stacks.GitHubActions,
      stacks.Bitbucket,
      stacks.AzureDevOps,
      stacks.Figma,
      stacks.VSCode,
      stacks.ESlint,
      stacks.Prettier,
      stacks.NPM,
    ],
  },
  {
    id: "ai",
    color: "#ec4899",
    heading: "AI Tools",
    description: "LLM-first tooling to ship AI-powered products.",
    icon: BrainIcon,
    skills: [stacks.GPT, stacks.V0, stacks.GoogleAIStudio, stacks.LangChain],
  },
  {
    id: "workflow",
    color: "#14b8a6",
    heading: "Workflow",
    description: "Planning, communication, and delivery methods.",
    icon: WorkflowIcon,
    skills: [
      stacks.Jira,
      stacks.Scrum,
      stacks.AzureBoards,
      stacks.GitHubBoards,
      stacks.Slack,
      stacks.Discord,
    ],
  },
  {
    id: "testing",
    color: "#f97316",
    heading: "Testing",
    description: "Confidence through repeatable testing and reviews.",
    icon: TestingIcon,
    skills: [stacks.Jest, stacks.Storybook, stacks.NUnit],
  },
];

const getEllipsePathStr = (rx: number, ry: number) =>
  `M -${rx} 0 A ${rx} ${ry} 0 1 1 ${rx} 0 A ${rx} ${ry} 0 1 1 -${rx} 0`;

const SCALE_X = 350;
const SCALE_Y = 140;
const ITEMS_PER_RING = 1;

const SOLAR_RINGS = [];
for (let i = 0; i < GROUPS.length; i += ITEMS_PER_RING) {
  const ringGroups = GROUPS.slice(i, i + ITEMS_PER_RING);
  const ringIdx = Math.floor(i / ITEMS_PER_RING);
  const totalRings = Math.ceil(GROUPS.length / ITEMS_PER_RING);
  const rotZ = ringIdx * (180 / totalRings);
  const rotX = 55 + (ringIdx % 2 === 0 ? 15 : 0);
  const spd = 24 + ringIdx * 3;

  SOLAR_RINGS.push({
    rx: SCALE_X,
    ry: SCALE_Y,
    spd,
    rotX,
    rotZ,
    groups: ringGroups,
  });
}

const groupsJson = JSON.stringify(GROUPS);
---

<section id="technologies" class="max-w-7xl mx-auto px-7 lg:px-0">
  <SectionHeader
    heading="Technologies"
    subheading="A digital ecosystem orbiting a single core. Click any group to explore its stack."
  />

  <div class="os-root overflow-visible pointer-events-none">
    <div
      class="relative w-full max-w-[700px] aspect-square flex items-center justify-center pointer-events-none [perspective:3000px] [transform-style:preserve-3d]"
    >
      <ul
        class="os-wrap pointer-events-none [transform-style:preserve-3d] [transform:translateZ(100px)]"
        id="os-wrap"
        data-groups={groupsJson}
      >
        <TechHub />

        {
          SOLAR_RINGS.map((ring, ridx) => {
            const pathStr = getEllipsePathStr(ring.rx, ring.ry);

            return (
              <li
                class="sol-ring-li w-0 h-0 [transform-style:preserve-3d] pointer-events-none"
                style={`--rz: ${ring.rotZ}deg; --rx: ${ring.rotX}deg; --rz-neg: -${ring.rotZ}deg; --rx-neg: -${ring.rotX}deg;`}
              >
                <svg
                  class="os-path-svg"
                  style={`--rx-val: ${ring.rx}; --ry-val: ${ring.ry};`}
                  viewBox={`-${ring.rx} -${ring.ry} ${ring.rx * 2} ${ring.ry * 2}`}
                >
                  <path
                    d={pathStr}
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1"
                    stroke-dasharray="4 4"
                    class="text-neutral-800/30 dark:text-white/10"
                  />
                </svg>

                {ring.groups.map((g, gi) => {
                  const delay =
                    -(gi / ring.groups.length) * ring.spd -
                    Math.random() * ring.spd;
                  return (
                    <div
                      class="os-item pointer-events-auto"
                      style={`--path: path('${pathStr}'); --spd: ${ring.spd}s; --dly: ${delay}s;`}
                    >
                      <div
                        class="os-counter"
                        style={`--rx-neg: -${ring.rotX}deg; --rz-neg: -${ring.rotZ}deg;`}
                      >
                        <button
                          class="os-gplanet"
                          data-gid={g.id}
                          style={`--pc:${g.color};`}
                        >
                          <div class="gp-icon flex items-center justify-center p-[1px]">
                             <Fragment set:html={g.icon} />
                          </div>
                          <span class="gp-count">{g.skills.length}</span>
                          <span class="gp-tip">{g.heading}</span>
                        </button>
                      </div>
                    </div>
                  );
                })}
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</section>

<script src="../../assets/js/technologies.js"></script>
