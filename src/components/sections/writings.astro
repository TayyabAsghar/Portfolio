---
import LinkButton from "../ui/link-button.astro";
import ListPosts from "../shared/list-posts.astro";
import SectionHeader from "../ui/section-header.astro";
---

<section id="writings" class="max-w-6xl mx-auto px-7 lg:px-0">
  <SectionHeader
    heading="My Writings"
    subheading="Along with coding I also like to write about technology and my experience with them. Here are some of my recent posts."
  />

  <div class="w-full mx-auto xl:px-0">
    <div class="flex flex-col items-center pb-7">
      <ListPosts count={3} />
    </div>
  </div>

  <div class="flex items-center justify-center w-full py-0">
    <LinkButton text="View All Writings" link="/blog" />
  </div>
</section>
