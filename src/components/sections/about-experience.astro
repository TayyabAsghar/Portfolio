---
import { Icon } from "astro-icon/components";

interface Props {
  logo: string;
  role: string;
  dates: string;
  company: string;
  website: string;
  detailsPage: string;
  description: string[];
  align?: "left" | "right";
}

const {
  logo,
  role,
  dates,
  company,
  website,
  description,
  detailsPage,
  align = "left",
} = Astro.props;

const isLeft = align === "left";
---

<article class:list={["relative mx-auto max-w-5xl py-4 md:py-8 experience-item opacity-0", isLeft ? "reveal-left" : "reveal-right"]}>
  <div
    class="absolute left-5 top-0 h-full w-px bg-neutral-200 dark:bg-neutral-800 md:left-1/2 md:-translate-x-1/2"
  >
  </div>

  <div
    class:list={[
      "grid items-start gap-4 grid-cols-[2.5rem_minmax(0,1fr)] md:grid-cols-[minmax(0,1fr)_4.5rem_minmax(0,1fr)]",
      isLeft ? "md:[&_.experience-copy]:text-right" : "",
    ]}
  >
    <div class="relative flex items-start justify-center md:hidden">
      <div
        class="company-logo-container z-10 flex h-10 w-10 items-center justify-center rounded-2xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 dark:border-neutral-700 dark:bg-neutral-950"
      >
        <a href={website} target="_blank" rel="noreferrer" class="block">
          <img src={logo} alt={company} class="h-5 w-5 object-contain" />
        </a>
      </div>
    </div>

    <div
      class:list={["experience-copy px-0 pt-0", isLeft ? "" : "md:col-start-3"]}
    >
      <p
        class:list={[
          "mb-3 text-xs font-semibold uppercase tracking-[0.24em] text-neutral-400 dark:text-neutral-500",
          isLeft ? "md:justify-self-end" : "",
        ]}
      >
        {dates}
      </p>

      <h3
        class="text-lg font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-xl"
      >
        {role}
      </h3>

      <div
        class:list={[
          "mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-neutral-600 dark:text-neutral-400",
          isLeft ? "md:justify-end" : "",
        ]}
      >
        <a
          href={website}
          target="_blank"
          rel="noreferrer"
          class="font-medium transition hover:text-neutral-900 dark:hover:text-white"
        >
          {company}
        </a>
      </div>

      <div
        class="mt-4 space-y-2.5 leading-7 text-neutral-600 dark:text-neutral-400 text-sm md:text-base"
      >
        {description.map((des) => des && <p class="m-0">{des}</p>)}
      </div>

      {
        !!detailsPage && (
          <a
            href={detailsPage}
            class="ruby more-link relative inline-flex items-center gap-1 text-sm font-medium text-neutral-500 hover:text-neutral-700 dark:text-neutral-400 dark:hover:text-neutral-200 transition-colors duration-200"
          >
            {align === "right" && (
              <Icon
                name="chevron-left"
                class="more-chevron-left w-3 h-3 animate-chevron-move-right"
              />
            )}

            <span>more</span>

            {align === "left" && (
              <Icon
                name="chevron-left"
                class="more-chevron-right w-3 h-3 animate-chevron-move-left"
              />
            )}
          </a>
        )
      }
    </div>

    <div
      class="relative hidden h-full items-start justify-center md:col-start-2 md:row-start-1 md:flex"
    >
      <div
        class="company-logo-container z-10 flex h-12 w-12 items-center justify-center rounded-2xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:scale-105 dark:border-neutral-700 dark:bg-neutral-950"
      >
        <a href={website} target="_blank" rel="noreferrer" class="block">
          <img src={logo} alt={company} class="h-6 w-6 object-contain" />
        </a>
      </div>
    </div>

    <div
      class:list={[
        "hidden md:block",
        isLeft ? "md:col-start-3" : "md:col-start-1 md:row-start-1",
      ]}
    >
    </div>
  </div>
</article>
